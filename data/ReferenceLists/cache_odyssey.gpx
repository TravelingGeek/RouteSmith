&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Where Can You Find Another One?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Here&amp;#39;s the best part—there&amp;#39;s a Cache Odyssey hide in &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;! That’s right! From coast to coast, every state in America is part of this grand adventure. Once you track down the one closest to you, why stop there?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;This cache is part of the Northeast Region Geotour. There are six exciting GeoTours making up this series which include a total of 50 accessible geocaches.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F3"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;East Central Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Illinois, Indiana, Kentucky, Michigan, North Carolina, Ohio, Tennessee, West Virginia, and Virginia&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F1"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Midwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Iowa, Kansas, Minnesota, Missouri, Nebraska, North Dakota, South Dakota, and Wisconsin &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F4"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northeast Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Connecticut, Delaware, Maryland, Maine, Massachusetts, New Hampshire, New Jersey, New York, Pennsylvania, Rhode Island, and Vermont &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F0"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alaska, Idaho, Montana, Oregon, Washington, and Wyoming &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F2"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;South Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alabama, Arkansas, Florida, Georgia, Louisiana, Mississippi, Oklahoma, South Carolina, and Texas  &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4EF"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Southwest Region&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt; &lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Arizona, California, Colorado, Hawaii, New Mexico, Nevada, and Utah.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:17pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#6aa84f;"&gt;&lt;strong&gt;Cache Odyssey Regional GeoTours Map&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com:443/b19ba586-1a55-44b3-8eb2-0781c0a8e99a.jpg" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;The Leaderboard!&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;For all you competitive geocachers who love racing to the finish line, we’ve got something just for you!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Retired Guy has put together a leaderboard for anyone who starts the journey. &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to complete their region?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to find all 50? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Which cache will receive the most favorite points? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Click on the Leaderboard button to find out!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
 &lt;/p&gt;

&lt;p&gt;&lt;a href="https://geocachetalk.com/cache-odyssey-leaderboard/"&gt;&lt;img src="https://img.geocaching.com:443/88d4ab19-c51e-452e-83af-e9e74fbe1bc2.jpg" width="100%" /&gt;&lt;/a&gt;&lt;/p&gt;
</groundspeak:long_description><groundspeak:encoded_hints /><groundspeak:logs><groundspeak:log id="1364265221"><groundspeak:date>2026-05-29T22:11:52</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="3591438">Felix 25</groundspeak:finder><groundspeak:text encoded="false">Mit Breun gemacht </groundspeak:text></groundspeak:log><groundspeak:log id="1364332893"><groundspeak:date>2026-05-29T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="7196707">M&amp;ADraper</groundspeak:finder><groundspeak:text encoded="false">#3798, TFTC! Picked this up while turning in the paperwork for the geotour. This is part of such a great series.</groundspeak:text></groundspeak:log><groundspeak:log id="1363032724"><groundspeak:date>2026-05-23T22:32:18</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="22998153">Geogurl35</groundspeak:finder><groundspeak:text encoded="false">Found while waiting to board the double decker bus for a history tour!  Lots of fun!  TFTC</groundspeak:text></groundspeak:log><groundspeak:log id="1363811840"><groundspeak:date>2026-05-23T12:00:00</groundspeak:date><groundspeak:type>Write note</groundspeak:type><groundspeak:finder id="3797805">mrahudson</groundspeak:finder><groundspeak:text encoded="false">Dropping a TB that is actually here that was listed in the Georgia Odyssey hide.</groundspeak:text></groundspeak:log><groundspeak:log id="1362975496"><groundspeak:date>2026-05-23T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="3797805">mrahudson</groundspeak:finder><groundspeak:text encoded="false">We deemed this one "close enough" to our route from Mississippi to New York to not pass up.  After finding the Cache Across America hide on the way here we found this one as well.  5th Odyssey find, first in the Northeast region.  TFTLBH!</groundspeak:text></groundspeak:log></groundspeak:logs></groundspeak:cache></wpt><wpt lat="34.091567" lon="-117.5823"><time>2024-12-29T00:00:00</time><name>GCB0JHF</name><desc>Cache Odyssey- California  by Larry the pool guy</desc><url>https://www.geocaching.com/geocache/GCB0JHF</url><urlname>Cache Odyssey- California </urlname><sym>Geocache</sym><type>Geocache|Letterbox Hybrid</type><groundspeak:cache id="9765451" available="true" archived="false"><groundspeak:name>Cache Odyssey- California </groundspeak:name><groundspeak:placed_by>Larry the pool guy</groundspeak:placed_by><groundspeak:owner id="2282299">Larry the pool guy</groundspeak:owner><groundspeak:type>Letterbox Hybrid</groundspeak:type><groundspeak:container>Regular</groundspeak:container><groundspeak:attributes><groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute><groundspeak:attribute id="41" inc="1">Stroller accessible</groundspeak:attribute><groundspeak:attribute id="1" inc="1">Dogs</groundspeak:attribute><groundspeak:attribute id="8" inc="1">Scenic view</groundspeak:attribute><groundspeak:attribute id="67" inc="1">GeoTour</groundspeak:attribute><groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute><groundspeak:attribute id="32" inc="1">Bicycles</groundspeak:attribute><groundspeak:attribute id="55" inc="1">Short hike (&lt;1 km)</groundspeak:attribute><groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute></groundspeak:attributes><groundspeak:difficulty>2.5</groundspeak:difficulty><groundspeak:terrain>1</groundspeak:terrain><groundspeak:country>United States</groundspeak:country><groundspeak:state>California</groundspeak:state><groundspeak:short_description /><groundspeak:long_description>&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com:443/177a3105-afb9-42a5-b70b-9373b72ce101.png" width="100%" /&gt;&lt;/p&gt;


&lt;p&gt; &lt;/p&gt;




&lt;h4&gt;&lt;strong&gt;What is Cache Odyssey?&lt;/strong&gt;&lt;/h4&gt;
Where Can You Find Another One?
&lt;strong&gt;Where Can You Find Another One?&lt;/strong&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Here's the best part—there's a Cache Odyssey hide in &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;! That’s right! From coast to coast, every state in America is part of this grand adventure. Once you track down the one closest to you, why stop there?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;This cache is part of the Northeast Region Geotour. There are six exciting GeoTours making up this series which include a total of 50 accessible geocaches.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F3"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;East Central Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Illinois, Indiana, Kentucky, Michigan, North Carolina, Ohio, Tennessee, West Virginia, and Virginia&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F1"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Midwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Iowa, Kansas, Minnesota, Missouri, Nebraska, North Dakota, South Dakota, and Wisconsin &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F4"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northeast Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Connecticut, Delaware, Maryland, Maine, Massachusetts, New Hampshire, New Jersey, New York, Pennsylvania, Rhode Island, and Vermont &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F0"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alaska, Idaho, Montana, Oregon, Washington, and Wyoming &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F2"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;South Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alabama, Arkansas, Florida, Georgia, Louisiana, Mississippi, Oklahoma, South Carolina, and Texas  &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4EF"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Southwest Region&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt; &lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Arizona, California, Colorado, Hawaii, New Mexico, Nevada, and Utah.&lt;/span&gt;

Here's the best part—there's a Cache Odyssey hide in every state! That’s right! From coast to coast, every state in America is part of this grand adventure. Once you track down the one closest to you, why stop there?

This cache is part of the Northeast Region Geotour. There are six exciting GeoTours making up this series which include a total of 50 accessible geocaches.

East Central Region GeoTour

Illinois, Indiana, Kentucky, Michigan, North Carolina, Ohio, Tennessee, West Virginia, and Virginia

Midwest Region GeoTour

Iowa, Kansas, Minnesota, Missouri, Nebraska, North Dakota, South Dakota, and Wisconsin 

Northeast Region GeoTour

Connecticut, Delaware, Maryland, Maine, Massachusetts, New Hampshire, New Jersey, New York, Pennsylvania, Rhode Island, and Vermont 

Northwest Region GeoTour

Alaska, Idaho, Montana, Oregon, Washington, and Wyoming 

South Region GeoTour

Alabama, Arkansas, Florida, Georgia, Louisiana, Mississippi, Oklahoma, South Carolina, and Texas  

Southwest Region GeoTour

Arizona, California, Colorado, Hawaii, New Mexico, Nevada, and Utah.


&lt;p&gt;&lt;em&gt;Cache Odyssey&lt;/em&gt; is a thrilling, nationwide geocaching journey like no other! Conceived by some of the top cache hiders in the U.S., this adventure brings a &lt;strong&gt;unique, highly creative letterbox&lt;/strong&gt; geocache to &lt;strong&gt;every state&lt;/strong&gt;.&lt;/p&gt;


&lt;p&gt;These caches are designed with &lt;strong&gt;everyone in mind&lt;/strong&gt;—from seasoned explorers to families with kids, and especially those geocaching in wheelchairs. Every cache is built to be fun, imaginative, and 100% &lt;strong&gt;accessible&lt;/strong&gt; to all.&lt;/p&gt;


&lt;hr /&gt;

&lt;h4&gt;&lt;strong&gt;What&amp;#39;s the Mission Behind Cache Odyssey?&lt;/strong&gt;&lt;/h4&gt;


&lt;p&gt;This isn&amp;#39;t your average cache series! We’re here to prove that &lt;strong&gt;geocaching&lt;/strong&gt; is a game for everyone—regardless of physical abilities or location. &lt;em&gt;Cache Odyssey&lt;/em&gt; aims to show that &lt;strong&gt;Terrain 1&lt;/strong&gt; caches can be just as daring and innovative as the most challenging hides. Because, after all, not every adventure needs to be a D5T5!&lt;/p&gt;


&lt;hr /&gt;

&lt;h4&gt;&lt;strong&gt;What Makes Cache Odyssey Special?&lt;/strong&gt;&lt;/h4&gt;


&lt;p&gt;When you embark on a &lt;em&gt;Cache Odyssey&lt;/em&gt; adventure, you can expect:&lt;/p&gt;


&lt;p&gt;✅ &lt;strong&gt;Wheelchair-accessible caches&lt;/strong&gt;: Every hide is designed for ease of access.&lt;br /&gt;

✅ &lt; vigorous&gt;Letterbox hybrids: Each cache combines the thrill of geocaching with the creativity of letterboxing.&lt;br /&gt;

✅ &lt; substantial&gt;Regular or larger containers: No micro hides here—get ready for some significant, satisfying finds!&lt;br /&gt;

✅ &lt;strong&gt;Unmatched creativity&lt;/strong&gt;: Prepare for some innovative, high-quality caches. Each one is designed to surprise and delight!&lt;/p&gt;


&lt;hr /&gt;

&lt;h4&gt;&lt;strong&gt;Where Can You Find Another One?&lt;/strong&gt;&lt;/h4&gt;


&lt;p&gt;Here&amp;#39;s the best part—there&amp;#39;s a &lt;em&gt;Cache Odyssey&lt;/em&gt; hide in &lt;strong&gt;every state&lt;/strong&gt;! 🌎 That’s right! From coast to coast, every state in America is part of this grand adventure. Once you track down the one closest to you, why stop there?&lt;/p&gt;


&lt;p&gt;Challenge yourself to find more &lt;em&gt;Cache Odyssey&lt;/em&gt; caches across the country, or maybe even plan to &lt;strong&gt;collect them all&lt;/strong&gt;! Feeling adventurous? 🌟 Check out the &lt;a href="www.geocachetalk.com/odyssey"&gt;full list of locations&lt;/a&gt; and start planning your geocaching quest today.&lt;/p&gt;


&lt;hr /&gt;

&lt;h4&gt;&lt;strong&gt;Start Your Cache Odyssey Adventure!&lt;/strong&gt;&lt;/h4&gt;


&lt;p&gt;Ready to hit the road? Whether you&amp;#39; re a seasoned geocacher or a curious newcomer, there&amp;#39;s an adventure waiting for you in every state. Begin your journey today and see how fun, accessible, and creative geocaching can be.&lt;/p&gt;


&lt;p&gt;Happy caching, and remember—&lt;strong&gt;the journey is the destination!&lt;/strong&gt; 🌟&lt;/p&gt;







&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Click on the Leaderboard button to find out!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
 &lt;/p&gt;

&lt;p&gt;&lt;a href="https://geocachetalk.com/cache-odyssey-leaderboard/"&gt;&lt;img src="https://img.geocaching.com:443/88d4ab19-c51e-452e-83af-e9e74fbe1bc2.jpg" width="100%" /&gt;&lt;/a&gt;&lt;/p&gt;

This cache can be found at the coordinates provided and is not offset.</groundspeak:long_description><groundspeak:encoded_hints>Small field puzzle to gain access to the key; everything is provided.</groundspeak:encoded_hints><groundspeak:logs><groundspeak:log id="1364874222"><groundspeak:date>2026-06-01T11:50:40</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="31518520">PapaMissa</groundspeak:finder><groundspeak:text encoded="false">Favo - hier haben wir das Geheimversteck gefunden und hatten uns schon gefreut in der Hoffnung den Schlüssel gefunden zu haben, aber dann mussten wir doch noch etwas weiter experimentieren, schlussendlich haben Zumba Brasil und ich diesen schönen Cache aus der Geotour erfolgreich finden und loggen können, vielen Dank 😀</groundspeak:text></groundspeak:log><groundspeak:log id="1364872989"><groundspeak:date>2026-06-01T11:44:48</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="31600633">ZumbaBrasil</groundspeak:finder><groundspeak:text encoded="false">Sehr schön gemacht, zusammen mit Papamissa geschafft.</groundspeak:text></groundspeak:log><groundspeak:log id="1360939460"><groundspeak:date>2026-05-14T09:59:22</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="609455">Data Wrangler</groundspeak:finder><groundspeak:text encoded="false">Took me a second or two, but I figured it out. Fun cache. Favorite. SL, TFTC.</groundspeak:text></groundspeak:log><groundspeak:log id="1359408658"><groundspeak:date>2026-05-05T12:00:00</groundspeak:date><groundspeak:type>Write note</groundspeak:type><groundspeak:finder id="2282299">Larry the pool guy</groundspeak:finder><groundspeak:text encoded="false"> If you take a Travel Bug from this location, you need to log the Travel Bug into your account. If you do not know how to do this, look up travel bugs via Groundspeak. They have tutorials on this subject. Right now, I have many bugs missing from recent visitors.</groundspeak:text></groundspeak:log><groundspeak:log id="1359404638"><groundspeak:date>2026-05-05T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="37997744">Val258</groundspeak:finder><groundspeak:text encoded="false">Awesome and fun cache! SL. TFTC!</groundspeak:text></groundspeak:log></groundspeak:logs></groundspeak:cache></wpt><wpt lat="43.660583" lon="-116.409417"><time>2024-11-05T00:00:00</time><name>GCB02TT</name><desc>Cache Odyssey - Idaho by railroad</desc><url>https://www.geocaching.com/geocache/GCB02TT</url><urlname>Cache Odyssey - Idaho</urlname><sym>Geocache</sym><type>Geocache|Letterbox Hybrid</type><groundspeak:cache id="9750333" available="true" archived="false"><groundspeak:name>Cache Odyssey - Idaho</groundspeak:name><groundspeak:placed_by>railroad</groundspeak:placed_by><groundspeak:owner id="500628">railroad</groundspeak:owner><groundspeak:type>Letterbox Hybrid</groundspeak:type><groundspeak:container>Regular</groundspeak:container><groundspeak:attributes><groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute><groundspeak:attribute id="41" inc="1">Stroller accessible</groundspeak:attribute><groundspeak:attribute id="67" inc="1">GeoTour</groundspeak:attribute><groundspeak:attribute id="13" inc="0">Available 24/7</groundspeak:attribute><groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute><groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute><groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute><groundspeak:attribute id="58" inc="1">Fuel nearby</groundspeak:attribute><groundspeak:attribute id="15" inc="1">Available in winter</groundspeak:attribute></groundspeak:attributes><groundspeak:difficulty>1.5</groundspeak:difficulty><groundspeak:terrain>1</groundspeak:terrain><groundspeak:country>United States</groundspeak:country><groundspeak:state>Idaho</groundspeak:state><groundspeak:short_description /><groundspeak:long_description>&lt;p&gt;&lt;img src="https://img.geocaching.com:443/81da709c-264b-4f44-9ec4-01116521d8bb.png" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;&lt;strong&gt;About this cache:&lt;/strong&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="color:#c0392b;"&gt;&lt;span style="font-size:16px;"&gt;The geocache is not at the posted coordinates.&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;This is a letterbox hybrid cache: click &lt;a href="https://www.geocaching.com/help/index.php?pg=kb.chapter&amp;amp;id=127&amp;amp;pgid=822"&gt;&lt;span style="color:#e74c3c;"&gt;here&lt;/span&gt;&lt;/a&gt; to learn more about this type of geocache. The self-inking stamp is not a trade item and is to remain with the cache.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;The Meridian Library Orchard Park Hours can be found &lt;a href="https://www.mld.org/branch/orchard-park"&gt;&lt;span style="color:#e74c3c;"&gt;here&lt;/span&gt;&lt;/a&gt;.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;At the posted coordinates is a dedication plaque for the library.  Please enter the last name of the second trustee listed in all lowercase letters for directions to the geocache.&lt;/span&gt;&lt;/p&gt;

&lt;div style="text-align:center;"&gt;&lt;a href="https://www.certitudes.org/certitude?wp=GCB02TT"&gt;&lt;img src="https://www.certitudes.org/logo?wp=GCB02TT" title="Click to see the list of solvers" /&gt;&lt;/a&gt;

&lt;div style="font-family:Comic Sans MS;"&gt;You can validate your puzzle solution with &lt;a href="https://www.certitudes.org/certitude?wp=GCB02TT"&gt;certitude&lt;/a&gt;.&lt;/div&gt;
&lt;/div&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;After you sign/stamp the logbook feel free to take an Idaho Potato pin.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;em&gt;This geocache was placed with the permission of Kristi Haman, Manager of the Orchard Park Branch, and the approval of the Meridian Library District.&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;h4&gt;The Link to the Northwest Passport can be found &lt;a href="https://geocachetalk.com/wp-content/uploads/2024/12/Cache-Odyssey-Northwest-GeoTour-Passport.pdf"&gt;here&lt;/a&gt;.&lt;/h4&gt;

&lt;h4&gt; &lt;/h4&gt;

&lt;table border="5" cellpadding="1" cellspacing="1"&gt;
	&lt;tbody&gt;
		&lt;tr&gt;
			&lt;td&gt;
			&lt;h4&gt;Congratulations to&lt;br /&gt;
			geo_doods &amp;amp; YourMomCaches&lt;br /&gt;
			for the FTF!&lt;/h4&gt;
			&lt;/td&gt;
		&lt;/tr&gt;
	&lt;/tbody&gt;
&lt;/table&gt;

&lt;h4&gt; &lt;/h4&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com:443/b1b969cc-4176-44a8-ae44-e0438c71e7f1.jpg" style="width:80%;" /&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:23pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Welcome to the Cache Odyssey! &lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;hr /&gt;
&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;What is Cache Odyssey?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Cache Odyssey is a thrilling, nationwide geocaching journey like no other! Conceived by some of the top cache hiders in the U.S., this adventure brings a &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;unique, highly creative letterbox&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; geocache to &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;These caches are designed with &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;everyone in mind&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;—from seasoned explorers to families with kids, and especially those geocaching in wheelchairs. Every cache is built to be fun, imaginative, and 100% &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;accessible&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; to all.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Where Can You Find Another One?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Here&amp;#39;s the best part—there&amp;#39;s a Cache Odyssey hide in &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;! That’s right! From coast to coast, every state in America is part of this grand adventure. Once you track down the one closest to you, why stop there?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;This cache is part of the Northwest Region Geotour. There are six exciting GeoTours making up this series which include a total of 50 accessible geocaches.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="https://coord.info/GT4F4"&gt;&lt;img src="https://img.geocaching.com:443/76de9cdc-8b3c-4816-8280-2fbc61852b60.jpg" /&gt;&lt;/a&gt; &lt;a href="https://coord.info/GT4F3"&gt;&lt;img src="https://img.geocaching.com:443/18d9b309-a90c-4900-a735-2eedd7912009.jpg" /&gt;&lt;/a&gt; &lt;a href="https://coord.info/GT4F2"&gt;&lt;img src="https://img.geocaching.com:443/0f404634-c476-4cd5-b8df-f85d6aa8069e.jpg" /&gt;&lt;/a&gt; &lt;a href="https://coord.info/GT4F1"&gt;&lt;img src="https://img.geocaching.com:443/dc93f2f7-97ae-4cb4-a9e1-8986f081414f.jpg" /&gt;&lt;/a&gt; &lt;a href="https://coord.info/GT4EF"&gt;&lt;img src="https://img.geocaching.com:443/179e8963-86e3-49a1-bc17-fd28c53b735a.jpg" /&gt;&lt;/a&gt; &lt;a href="https://coord.info/GT4F0"&gt;&lt;img src="https://img.geocaching.com:443/f6ab1d02-9794-4521-955f-0bcf19e3c566.jpg" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com:443/ba935c3f-3961-459a-a950-8b1462cbe818.jpg" /&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="https://www.RetiredGuy.com/CacheOdyssey.html" target="_blank"&gt;&lt;img alt="Cache Odyssey Leaderboard" src="https://www.dropbox.com/scl/fi/ygks8c1e4p0rrvu3wxy1r/CacheOdysseyNorthwest.jpg?rlkey=31rfiszkb03kf3n9o88sdfifk&amp;amp;st=do7a8866&amp;amp;raw=1" /&gt;&lt;/a&gt;&lt;/p&gt;
</groundspeak:long_description><groundspeak:encoded_hints /><groundspeak:logs><groundspeak:log id="1364745449"><groundspeak:date>2026-05-31T16:52:01</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="2909634">JL_HSTRE</groundspeak:finder><groundspeak:text encoded="false">Found on my journey westward, after visiting the state museum. I made it here a half hour before closing. Searching proved fruitless so I sought help from a librarian. It wasn't on the usual shelf, though in a manner of thinking it's not wrong. I put back where the librarian said it usual resides, which fits the hint.

What confused me was it's not in a location that makes sense for the Dewey Decimal system.</groundspeak:text></groundspeak:log><groundspeak:log id="1364465985"><groundspeak:date>2026-05-30T15:20:28</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="2131292">Peregrine714</groundspeak:finder><groundspeak:text encoded="false">First I have heard or Cache Odyssey! Will have to find more of them. Cache was not located as described, but I returned it to the proper location. Tftc </groundspeak:text></groundspeak:log><groundspeak:log id="1364100994"><groundspeak:date>2026-05-28T16:03:17</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="52268050">bharr8644</groundspeak:finder><groundspeak:text encoded="false">Was at the library when I saw it cool find</groundspeak:text></groundspeak:log><groundspeak:log id="1363929915"><groundspeak:date>2026-05-27T13:32:18</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="55499861">danielChorizo</groundspeak:finder><groundspeak:text encoded="false">Thank you! </groundspeak:text></groundspeak:log><groundspeak:log id="1363745745"><groundspeak:date>2026-05-26T11:06:24</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="9366409">rickdorsey8080</groundspeak:finder><groundspeak:text encoded="false">The journey to find this Odyssey started in Rhode Island four days prior. Flew from Boston to Portland, then to Boise for Memorial Day, and now here I am in Meridian. The library was alive this morning and I found my target after a short search. It was kind of hard to miss on the shelf. This is Odyssey #42 for me, and my fourth in the Northwest Region. Grabbed the final potato pin as a memento before my flight east. FPadded, Tftc</groundspeak:text></groundspeak:log></groundspeak:logs></groundspeak:cache></wpt><wpt lat="36.805833" lon="-76.22855"><time>2024-10-13T00:00:00</time><name>GCAZ50H</name><desc>Cache Odyssey-Virginia by PA Ladi</desc><url>https://www.geocaching.com/geocache/GCAZ50H</url><urlname>Cache Odyssey-Virginia</urlname><sym>Geocache</sym><type>Geocache|Letterbox Hybrid</type><groundspeak:cache id="9722642" available="true" archived="false"><groundspeak:name>Cache Odyssey-Virginia</groundspeak:name><groundspeak:placed_by>PA Ladi</groundspeak:placed_by><groundspeak:owner id="137617">PA Ladi</groundspeak:owner><groundspeak:type>Letterbox Hybrid</groundspeak:type><groundspeak:container>Regular</groundspeak:container><groundspeak:attributes><groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute><groundspeak:attribute id="67" inc="1">GeoTour</groundspeak:attribute><groundspeak:attribute id="13" inc="0">Available 24/7</groundspeak:attribute></groundspeak:attributes><groundspeak:difficulty>1</groundspeak:difficulty><groundspeak:terrain>1</groundspeak:terrain><groundspeak:country>United States</groundspeak:country><groundspeak:state>Virginia</groundspeak:state><groundspeak:short_description /><groundspeak:long_description>&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;strong&gt;THE CACHE IS NOT INSIDE THE BUILDING! THERE IS NO NEED TO GO INSIDE!&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;strong&gt;&lt;span style="font-size:16px;"&gt;I&amp;#39;VE ADDED A LOCK TO THE CONTAINER. SEE HINT FOR CODE AND OPERATION&lt;/span&gt;&lt;/strong&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:20px;"&gt;&lt;strong&gt;PLEASE DO NOT TAKE THE STAMP!!!!!&lt;/strong&gt;&lt;/span&gt;&lt;span style="font-size:16px;"&gt;&lt;strong&gt;  This is the third stamp I&amp;#39;ve purchased for this cache.  If you really need to take the stamp please leave $30 so I can get a replacement.  Thank you!&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;img src="https://img.geocaching.com:443/ca87c6ff-e691-4737-b5ca-aaae1d57933b.png" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt;Cache is located at the Rokeby Senior Center. It is on Chesapeake City Park property and available sunrise to sunset. The center is open Monday-Friday 9AM-4PM and Saturday 9AM-1PM. You may see participants coming and going during those hours. Staff is aware of the cache, but most participants are not.&lt;/p&gt;

&lt;p&gt;Cache is a letterbox. **PLEASE DO NOT TAKE THE STAMP!!**&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;&lt;img src="https://img.geocaching.com:443/b1b969cc-4176-44a8-ae44-e0438c71e7f1.jpg" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h2&gt;&lt;span style="font-size:23pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Welcome to the Cache Odyssey! &lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h2&gt;

&lt;p&gt; &lt;/p&gt;

&lt;hr /&gt;
&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;What is Cache Odyssey?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Cache Odyssey is a thrilling, nationwide geocaching journey like no other! Conceived by some of the top cache hiders in the U.S., this adventure brings a &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;unique, highly creative letterbox&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; geocache to &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;These caches are designed with &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;everyone in mind&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;—from seasoned explorers to families with kids, and especially those geocaching in wheelchairs. Every cache is built to be fun, imaginative, and 100% &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;accessible&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; to all.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;hr /&gt;
&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Where Can You Find Another One?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Here&amp;#39;s the best part—there&amp;#39;s a Cache Odyssey hide in &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;! That’s right! From coast to coast, every state in America is part of this grand adventure. Once you track down the one closest to you, why stop there?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;This cache is part of the East Central Region Geotour. There are six exciting GeoTours making up this series which include a total of 50 accessible geocaches.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F3"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;East Central Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Illinois, Indiana, Kentucky, Michigan, North Carolina, Ohio, Tennessee, West Virginia, and Virginia&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F1"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Midwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Iowa, Kansas, Minnesota, Missouri, Nebraska, North Dakota, South Dakota, and Wisconsin &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F4"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northeast Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Connecticut, Delaware, Maryland, Maine, Massachusetts, New Hampshire, New Jersey, New York, Pennsylvania, Rhode Island, and Vermont &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F0"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alaska, Idaho, Montana, Oregon, Washington, and Wyoming &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F2"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;South Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alabama, Arkansas, Florida, Georgia, Louisiana, Mississippi, Oklahoma, South Carolina, and Texas  &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4EF"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Southwest Region&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt; &lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Arizona, California, Colorado, Hawaii, New Mexico, Nevada, and Utah.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:17pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#6aa84f;"&gt;&lt;strong&gt;Cache Odyssey Regional GeoTours Map&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com:443/b19ba586-1a55-44b3-8eb2-0781c0a8e99a.jpg" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;The Leaderboard!&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;For all you competitive geocachers who love racing to the finish line, we’ve got something just for you!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;RetiredGuy has put together a leaderboard for anyone who starts the journey. &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to complete their region?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to find all 50? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Which cache will receive the most favorite points? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Click on the Leaderboard button to find out!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
 &lt;/p&gt;

&lt;p&gt;&lt;a href="https://geocachetalk.com/cache-odyssey-leaderboard/"&gt;&lt;img src="https://img.geocaching.com:443/88d4ab19-c51e-452e-83af-e9e74fbe1bc2.jpg" width="100%" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;
</groundspeak:long_description><groundspeak:encoded_hints>seven zero nine Line numbers with the white circles, move right cable to the left and pull.  To reset insert cable, move to the right and turn the numbers to zeros.  THANKS!</groundspeak:encoded_hints><groundspeak:logs><groundspeak:log id="1364107914"><groundspeak:date>2026-05-28T20:10:52</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="55310627">_MarktheSpot_</groundspeak:finder><groundspeak:text encoded="false">Awesome Cache!  It is stuffed! Stamped and traded and put everything back where they belong. Thank you!</groundspeak:text></groundspeak:log><groundspeak:log id="1363813954"><groundspeak:date>2026-05-26T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="5268266">Pine Baron</groundspeak:finder><groundspeak:text encoded="false">5528. Second day heading from GA to NJ with Piglet404 and had this one on the list. This would be our last stop of the day, and it was worth it! The cache was loaded with SWAG, so we swapped stamps, signed the log and did some trading. All's well here. The lock was a good idea! Thanx for the fun Odyssey!</groundspeak:text></groundspeak:log><groundspeak:log id="1361475749"><groundspeak:date>2026-05-16T14:36:58</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="11181996">DTCharlie</groundspeak:finder><groundspeak:text encoded="false">Very easy to cache find. I can see how the stamp keeps disappearing. Nice to get out of the car for a little while.
On a weeklong vacation road trip in my way down to Florida. Trying to find all kinds of sites to see and things to do. Of course I’m gonna pick up any geocache odyssey is I can along the way. 
Very pretty little park here. The center is closed, but of course it’s OK to find this geocache. 
Thank you to the CEO for placing and maintaining this geocache for all to find. </groundspeak:text></groundspeak:log><groundspeak:log id="1362173225"><groundspeak:date>2026-05-15T20:09:52</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="25469529">lindsayasdnil</groundspeak:finder><groundspeak:text encoded="false">Love this series! 
Fun location providing some nice chat with locals, bought a book in the book sale 
Did some wandering around and learning. 
Lots of fun here and a fav point for sure!! 
Signed in and off on our next adventure </groundspeak:text></groundspeak:log><groundspeak:log id="1363033096"><groundspeak:date>2026-05-15T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="25469328">Missbderycke</groundspeak:finder><groundspeak:text encoded="false">Phone in Airplane Mode, Work Phone &amp; Laptop Shut Off, 5 days. 4 New States. 5 CAAs, 4 Cache Odysseys, 3000+ km driving, 25+km on foot, a lifetime of laughs &amp; memories = priceless.

Here is a short story long... in booking a hotel in November of 2025 I was asked to stay on the line and listen to an offer. While listening I was getting ready to head out on a hike with a friend so Im not going to lie I was paying zero attention. Afterward the lady was like does that sound good and I answered yes which prompted her to ask for my credit card number. Still not paying attention to what was going on and thinking I was paying for the November hotel I ended up with a 3 night 4 day stay to 11 different locations in the US for a really good deal. When I saw the email stating what I had just signed up for I called lindsayasdnil and said well I did this thing so pick from these 11 locations and we will go on a geotrip! She ended up deciding on Williamsburg, VA as it was one we could drive to and the closest-ish one. Now just to decide when we would go. We seem to like to road trip in May so we decided on doing that again and combine it with a milestone birthday for her. Since my goal is to visit all of the states and also complete this series while doing so we chatted about tacking on an extra day and visiting Delaware as neither of us had it as a state we were planning on visiting for a specific reason (but boy am I sure glad we did, more on this later). About a week before leaving I convinced her that we werent far from the New Jersey CAA either and we would be driving super close to the North Carolina border so we might as well pop down there for a hot minute and grab a cache as well.

We left Niagara Falls, ON yesterday at 7:45am and arrived at our hotel at 11:03pm and were pooped so we slept in this morning. Such a beautiful state. We both decided quite quickly after waking up this morning and driving around that people are sleeping on Delaware. No one talks about how beautiful it is here! We believe it's a hidden gem and we will be back again as soon as we can!

After an unexpected brief drive through Maryland we ended up in Virginia finally we left the hotel at 9am and its nearly 5pm and we haven't travelled nearly as far as expected today yet, going to be another long one. Chesapeake Bay bridge has been on my bucket list for a few years so I am excited to finally be doing this. This is our third cache odyssey on this trip. We made it here as the sun was starting to set. I can see why this one goes missing frequently. Tftc!</groundspeak:text></groundspeak:log></groundspeak:logs></groundspeak:cache></wpt><wpt lat="39.701667" lon="-75.5506"><time>2024-12-18T00:00:00</time><name>GCB04HE</name><desc>Cache Odyssey - Delaware by benlorma07</desc><url>https://www.geocaching.com/geocache/GCB04HE</url><urlname>Cache Odyssey - Delaware</urlname><sym>Geocache</sym><type>Geocache|Letterbox Hybrid</type><groundspeak:cache id="9751996" available="true" archived="false"><groundspeak:name>Cache Odyssey - Delaware</groundspeak:name><groundspeak:placed_by>benlorma07</groundspeak:placed_by><groundspeak:owner id="9350479">benlorma07</groundspeak:owner><groundspeak:type>Letterbox Hybrid</groundspeak:type><groundspeak:container>Regular</groundspeak:container><groundspeak:attributes><groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute><groundspeak:attribute id="67" inc="1">GeoTour</groundspeak:attribute><groundspeak:attribute id="13" inc="0">Available 24/7</groundspeak:attribute><groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute><groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute><groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute><groundspeak:attribute id="26" inc="1">Public transportation nearby</groundspeak:attribute></groundspeak:attributes><groundspeak:difficulty>2</groundspeak:difficulty><groundspeak:terrain>1</groundspeak:terrain><groundspeak:country>United States</groundspeak:country><groundspeak:state>Delaware</groundspeak:state><groundspeak:short_description /><groundspeak:long_description>&lt;p&gt;&lt;img src="https://img.geocaching.com:443/085ef39f-7673-44fc-945f-3579422587dc.png" width="100%" /&gt;&lt;/p&gt;


&lt;p&gt;This cache is part of the Cache Odyssey GeoTour series which is made up of six GeoTours and has a letterbox in each state.  This cache is part of the &lt;a href="https://coord.info/GT4F4"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northeast Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;.  More on Cache Odyssey later.&lt;/p&gt;

&lt;p&gt;&lt;b&gt;This cache is not at the posted coordinates.&lt;/b&gt;  You will need to start by visiting the posted coordinates to get information on how to find this letterbox hybrid cache.  The cache is located inside of the Route 9 Library &amp;amp; Innovation Center and is only available when the library is open.&lt;/p&gt;

&lt;p&gt;The hours for the library are the following:&lt;br /&gt;
10:00am - 9:00pm Monday - Wednesday&lt;br /&gt;
10:00am - 5:00pm Friday - Saturday&lt;br /&gt;
1:00pm - 5:00pm Sunday&lt;br /&gt;
Closed on Thursday and on holidays.&lt;/p&gt;

&lt;p&gt;Be sure to check current hours at the library &lt;a href="https://www.newcastlede.gov/1389/Route-9-Library-Innovation-Center"&gt;website&lt;/a&gt; before going.  This cache was placed with permission and assistance from Alix Jefferson, Manager of the Library.&lt;/p&gt;

&lt;p&gt;Please do not take either stamp or the ink pad.  One stamp is for stamping your Cache Odyssey &lt;a href="https://geocachetalk.com/wp-content/uploads/2024/12/Cache-Odyssey-Northeast-GeoTour-Passport.pdf"&gt;passport&lt;/a&gt; and the other is a more traditional stamp commonly seen in letterboxes.  A pen is provided in the cache, but in case it goes missing it is a good idea to bring your own as there is no credit for a find if you do not sign the log book.  There is room for small trade items and trackables.&lt;/p&gt;

&lt;p&gt;To obtain the letterbox instructions to find this letterbox hybrid geocache go to the posted coordinates which should put you next to a flag pole in front of the library.  On the ground next to the flag pole is a memorial stone for someone.  &lt;b&gt;Put the last name of that person into the Certitude link below to receive the instructions to find this cache.&lt;/b&gt;&lt;/p&gt;

&lt;div style="text-align:center;"&gt;
&lt;a href="https://www.certitudes.org/certitude?wp=GCB04HE"&gt;
&lt;img src="https://www.certitudes.org/logo?wp=GCB04HE" title="Click to see the list of solvers" style="filter:drop-shadow(3px 3px 3px #CCC);" /&gt;&lt;/a&gt;
&lt;div style="font-family:Comic Sans MS;"&gt;You can validate your puzzle solution with &lt;a href="https://www.certitudes.org/certitude?wp=GCB04HE"&gt;certitude&lt;/a&gt;.&lt;/div&gt;
&lt;/div&gt;

&lt;hr /&gt;
&lt;br /&gt;
&lt;p&gt;Here are links to the passports for the six GeoTours.  The passports are just for you to printout and to keep track of your progress.  Each Cache Odyssey cache has a stamp that can be used to stamp the passport to show that you found the cache.  A digital souvenir is earned for finding each cache in a GeoTour (a different souvenir for each of the six GeoTours).  A seventh souvenir can be earned for finding all 50 of the Cache Odyssey caches!  The passports are not required, they are just so you can keep track of your progress on paper. &lt;p&gt;

&lt;ul&gt;
 &lt;li&gt; &lt;a href="https://geocachetalk.com/wp-content/uploads/2024/12/Cache-Odyssey-East-Central-GeoTour-Passports.pdf"&gt;East Central Passport&lt;/a&gt;&lt;/li&gt;
 &lt;li&gt; &lt;a href="https://geocachetalk.com/wp-content/uploads/2024/12/Cache-Odyssey-Midwest-GeoTour-Passports.pdf"&gt;Midwest Passport&lt;/a&gt;&lt;/li&gt;
 &lt;li&gt; &lt;a href="https://geocachetalk.com/wp-content/uploads/2024/12/Cache-Odyssey-Northeast-GeoTour-Passport.pdf"&gt;Northeast Passport&lt;/a&gt; (The one this cache belongs to)&lt;/li&gt;
 &lt;li&gt; &lt;a href="https://geocachetalk.com/wp-content/uploads/2024/12/Cache-Odyssey-Northwest-GeoTour-Passport.pdf"&gt;Northwest Passport&lt;/a&gt;&lt;/li&gt;
 &lt;li&gt; &lt;a href="https://geocachetalk.com/wp-content/uploads/2024/12/Cache-Odyssey-South-GeoTour-Passport.pdf"&gt;South Passport&lt;/a&gt;&lt;/li&gt;
 &lt;li&gt; &lt;a href="https://geocachetalk.com/wp-content/uploads/2024/12/Cache-Odyssey-Southwest-GeoTour-Passport.pdf"&gt;Southwest Passport&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;hr /&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;&lt;img src="https://img.geocaching.com:443/b1b969cc-4176-44a8-ae44-e0438c71e7f1.jpg" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h2&gt;&lt;span style="font-size:23pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Welcome to the Cache Odyssey! &lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h2&gt;

&lt;p&gt; &lt;/p&gt;

&lt;hr /&gt;
&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;What is Cache Odyssey?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Cache Odyssey is a thrilling, nationwide geocaching journey like no other! Conceived by some of the top cache hiders in the U.S., this adventure brings a &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;unique, highly creative letterbox&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; geocache to &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;These caches are designed with &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;everyone in mind&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;—from seasoned explorers to families with kids, and especially those geocaching in wheelchairs. Every cache is built to be fun, imaginative, and 100% &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;accessible&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; to all.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;hr /&gt;
&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Where Can You Find Another One?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Here&amp;#39;s the best part—there&amp;#39;s a Cache Odyssey hide in &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;! That’s right! From coast to coast, every state in America is part of this grand adventure. Once you track down the one closest to you, why stop there?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;This cache is part of the Northeast Region Geotour. There are six exciting GeoTours making up this series which include a total of 50 accessible geocaches.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F3"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;East Central Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Illinois, Indiana, Kentucky, Michigan, North Carolina, Ohio, Tennessee, West Virginia, and Virginia&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F1"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Midwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Iowa, Kansas, Minnesota, Missouri, Nebraska, North Dakota, South Dakota, and Wisconsin &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F4"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northeast Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Connecticut, Delaware, Maryland, Maine, Massachusetts, New Hampshire, New Jersey, New York, Pennsylvania, Rhode Island, and Vermont &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F0"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alaska, Idaho, Montana, Oregon, Washington, and Wyoming &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F2"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;South Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alabama, Arkansas, Florida, Georgia, Louisiana, Mississippi, Oklahoma, South Carolina, and Texas  &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4EF"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Southwest Region&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt; &lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Arizona, California, Colorado, Hawaii, New Mexico, Nevada, and Utah.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:17pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#6aa84f;"&gt;&lt;strong&gt;Cache Odyssey Regional GeoTours Map&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com:443/b19ba586-1a55-44b3-8eb2-0781c0a8e99a.jpg" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;The Leaderboard!&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;For all you competitive geocachers who love racing to the finish line, we’ve got something just for you!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;RetiredGuy has put together a leaderboard for anyone who starts the journey. &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to complete their region?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to find all 50? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Which cache will receive the most favorite points? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Click on the Leaderboard button to find out!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
 &lt;/p&gt;

&lt;p&gt;&lt;a href="https://geocachetalk.com/cache-odyssey-leaderboard/"&gt;&lt;img src="https://img.geocaching.com:443/88d4ab19-c51e-452e-83af-e9e74fbe1bc2.jpg" width="100%" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;/p&gt;&lt;/p&gt;</groundspeak:long_description><groundspeak:encoded_hints /><groundspeak:logs><groundspeak:log id="1365003808"><groundspeak:date>2026-06-02T13:14:10</groundspeak:date><groundspeak:type>Unknown</groundspeak:type><groundspeak:finder id="9350479">benlorma07</groundspeak:finder><groundspeak:text encoded="false">Checked on this today, still plenty of room in log book, happy caching 😊</groundspeak:text></groundspeak:log><groundspeak:log id="1364265140"><groundspeak:date>2026-05-29T22:10:01</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="3591438">Felix 25</groundspeak:finder><groundspeak:text encoded="false">Mit Breun gemacht </groundspeak:text></groundspeak:log><groundspeak:log id="1364606375"><groundspeak:date>2026-05-27T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="3404990">Breun</groundspeak:finder><groundspeak:text encoded="false">We spent two weeks in the USA visiting relatives. Two weeks doing absolutely nothing and not thinking about work. But geocaching wasn't completely forgotten. Our son made sure of that. A few days in Washington brought us to discover some new states and a few virtual ones.

Thanks for placing and maintaining the caches. Greetings from the beautiful Bergisches Land region.



Für zwei Wochen ging es in die USA, die Verwandschaft besuchen. Zwei Wochen einmal nichts tun und nicht an die Arbeit denken. Aber das Geocaching wurde dabei nicht ganz vergessen. Da passte vor allem der Junior drauf auf. Ein paar Tage nach Washington brachte ein paar neue Bundesstaaten und einige Virtuelle.

Danke fürs legen und pflegen der Dosen. Viele Grüße aus dem schönen Bergischen Land.</groundspeak:text></groundspeak:log><groundspeak:log id="1363774548"><groundspeak:date>2026-05-26T15:33:36</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="48257468">Ditchmark88</groundspeak:finder><groundspeak:text encoded="false">3:33 pm
I left Vermont this morning on a work trip in Maryland. Not my favorite drive but today went pretty well. I’m spending the night a few miles from here and noticed all the hearts! I do believe this is my first indoor cache out of almost 2000 finds. Thank you for that. </groundspeak:text></groundspeak:log><groundspeak:log id="1361651226"><groundspeak:date>2026-05-16T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="10449080">fuzzydave</groundspeak:finder><groundspeak:text encoded="false">Find #13,075

Found myself headed north to attend a wedding and figured I'd make it a more productive drive with a few stops for caches.

I stopped for this because I need to find two more letterboxes this month for a challenge.
Id forgotten about this series til I saw on the map a cache with 150 fps and it's indoors.

My low-key favorite part of library hides is access to a clean bathroom.

I actually made quick work of the instructions.

Got my name on the log and replaced as found.

Cache is nice and dry inside</groundspeak:text></groundspeak:log></groundspeak:logs></groundspeak:cache></wpt><wpt lat="41.477817" lon="-75.183833"><time>2024-12-31T00:00:00</time><name>GCAXXMV</name><desc>Cache Odyssey - Pennsylvania by CaptainMath</desc><url>https://www.geocaching.com/geocache/GCAXXMV</url><urlname>Cache Odyssey - Pennsylvania</urlname><sym>Geocache</sym><type>Geocache|Letterbox Hybrid</type><groundspeak:cache id="9685792" available="false" archived="false"><groundspeak:name>Cache Odyssey - Pennsylvania</groundspeak:name><groundspeak:placed_by>CaptainMath</groundspeak:placed_by><groundspeak:owner id="530518">captainmath</groundspeak:owner><groundspeak:type>Letterbox Hybrid</groundspeak:type><groundspeak:container>Large</groundspeak:container><groundspeak:attributes><groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute><groundspeak:attribute id="67" inc="1">GeoTour</groundspeak:attribute><groundspeak:attribute id="13" inc="0">Available 24/7</groundspeak:attribute><groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute></groundspeak:attributes><groundspeak:difficulty>3.5</groundspeak:difficulty><groundspeak:terrain>1</groundspeak:terrain><groundspeak:country>United States</groundspeak:country><groundspeak:state>Pennsylvania</groundspeak:state><groundspeak:short_description /><groundspeak:long_description>&lt;p&gt;&lt;a href="https://www.geocaching.com/play/geotours/cacheodyssey-northeast"&gt;&lt;img src="https://img.geocaching.com:443/085ef39f-7673-44fc-945f-3579422587dc.png" width="100%" /&gt;&lt;/a&gt;&lt;/p&gt;
&lt;p&gt;&lt;center&gt;&lt;img src="https://s3.amazonaws.com/gs-geo-images/4c573b3c-9b15-4152-aa0f-b773bebb3c0b.png" /&gt;&lt;/center&gt;&lt;/p&gt;
&lt;p align="center"&gt;
&lt;b&gt;PLAN AHEAD!&lt;br /&gt;LOCATION HOURS TO COMPLETE THIS CACHE&lt;/b&gt;&lt;br /&gt;
Monday:  CLOSED&lt;br /&gt;
Tuesday:  9:30 AM - 5 PM&lt;br /&gt;
Wednesday:  9:30 AM - 3 PM&lt;br /&gt;
Thursday:  9:30 AM - 5 PM&lt;br /&gt;
Friday:  9:30 AM - 3 PM&lt;br /&gt;
Saturday:  9:30 AM - 1 PM&lt;br /&gt;
Sunday:  CLOSED&lt;br /&gt;
&lt;a href="https://wayne.chilipac.com/eg/opac/library/WAPI_WHW"&gt;Click Here to check for any upcoming special closings&lt;/a&gt;
&lt;/p&gt;


&lt;font size="+1"&gt;
&lt;hr /&gt;



&lt;p&gt;Welcome to &lt;b&gt;Hawley, Pennsylvania&lt;/b&gt;, host to the Keystone State's piece of the Cache Odyssey series, and an introduction to what makes this area such a special part of the birth and growth of our nation.&lt;/p&gt;

&lt;p&gt;This region of Northeastern Pennsylvania played a huge part in the early industrial growth of our nation. Whether you live here or have traveled here from afar, you should know this one thing – Northeastern PA had a treasure that was needed for the spread of our young nation – anthracite coal.&lt;/p&gt;

&lt;p&gt;But in the early 19th century getting this precious coal to where it was needed required the creation of a very special “new” technology: &lt;b&gt; the Gravity Railroad&lt;/b&gt;. This geocache celebrates this special part of our area’s history.&lt;/p&gt;

&lt;P&gt;&lt;HR /&gt;&lt;/P&gt;&lt;BR /&gt;

&lt;CENTER&gt;&lt;b&gt;HOW TO COMPLETE THIS GEOCACHE&lt;/B&gt;&lt;/CENTER&gt;

&lt;p&gt;&lt;ol&gt;
&lt;li&gt;&lt;a href="https://youtu.be/yFsQm1x6LDQ?si=ZFD7-hAeJ1SQa1aX"&gt;&lt;b&gt;Please watch this brief video. Perhaps it's best if you watch this before coming to the posted coordinates.&lt;/b&gt;&lt;/a&gt;&lt;b&gt;&lt;/b&gt;&lt;/li&gt;
&lt;li&gt;Once you arrive on site, near the posted coordinates you will find &lt;b&gt;two&lt;/b&gt; very large, old remnants of local history very close together. One of them is an actual passenger car from the Gravity Railroad which ran right here in Hawley more than a century ago. The other is a large metal object with a four-digit number on it on two sides. &lt;i&gt;Remember this four-digit number.&lt;/i&gt;&lt;/li&gt;
&lt;li&gt;Proceed inside to the computer lab and do a &lt;i&gt;keyword search&lt;/i&gt; of the library’s electronic catalog for the main topic of the video you watched. Find the referenced book on site and follow the instructions therein. &lt;i&gt;Allow yourself time as this is NOT a park and grab.&lt;/i&gt; You must sign the log book to claim a “find” and you can also use the official stamp to stamp your passport for the Cache Odyssey Northeast Region Geo-Tour; do not keep the stamper - it must stay with this cache.&lt;/li&gt;
&lt;/ol&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;
&lt;p&gt;Note that the unusual nature of this genuinely LARGE geocache only allows for small trackables to be stored in the compartment with the log book and stamper.&lt;/p&gt;
&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;
&lt;p align="center"&gt;If you enjoyed this special geocache, you'll also like our new, Cache Odyssey style cache,&lt;br /&gt;&lt;a href="https://coord.info/GCB28FG"&gt;&lt;b&gt;&lt;font color="red" size="+3"&gt;Power at 'Paupack&lt;/font&gt;&lt;/b&gt;&lt;/a&gt;,&lt;br /&gt; a very large hands-on gadget geocaching lesson on hydroelectric power. It's only five minutes away from Cache Odyssey Pennsylvania!&lt;/p&gt;
&lt;p&gt; &lt;/p&gt;

&lt;p&gt;&lt;hr /&gt;&lt;/p&gt;
&lt;p&gt;&lt;img src="https://img.geocaching.com:443/b1b969cc-4176-44a8-ae44-e0438c71e7f1.jpg" width="100%" /&gt;&lt;/p&gt;
&lt;/font&gt;

&lt;h2&gt;&lt;span style="font-size:23pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Welcome to the Cache Odyssey! &lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h2&gt;


&lt;h3&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;What is Cache Odyssey?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Cache Odyssey is a thrilling, nationwide geocaching journey like no other! Conceived by some of the top cache hiders in the U.S., this adventure brings a &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;unique, highly creative letterbox&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; geocache to &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;These caches are designed with &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;everyone in mind&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;—from seasoned explorers to families with kids, and especially those geocaching in wheelchairs. Every cache is built to be fun, imaginative, and 100% &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;accessible&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; to all.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Where Can You Find Another One?   &lt;a href="https://coord.info/BME2KPX"&gt;Other Cache Odyssey Caches&lt;/a&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;



&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Here&amp;#39;s the best part—there&amp;#39;s a Cache Odyssey hide in &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;! That’s right! From coast to coast, every state in America is part of this grand adventure. Once you track down the one closest to you, why stop there?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;This cache is part of the Northeast Region Geotour. There are six exciting GeoTours making up this series which include a total of 50 accessible geocaches.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F4"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northeast Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Connecticut, Delaware, Maryland, Maine, Massachusetts, New Hampshire, New Jersey, New York, Pennsylvania, Rhode Island, and Vermont &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F3"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;East Central Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Illinois, Indiana, Kentucky, Michigan, North Carolina, Ohio, Tennessee, West Virginia, and Virginia&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F1"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Midwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Iowa, Kansas, Minnesota, Missouri, Nebraska, North Dakota, South Dakota, and Wisconsin &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;


&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F0"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alaska, Idaho, Montana, Oregon, Washington, and Wyoming &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F2"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;South Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alabama, Arkansas, Florida, Georgia, Louisiana, Mississippi, Oklahoma, South Carolina, and Texas  &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4EF"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Southwest Region&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt; &lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Arizona, California, Colorado, Hawaii, New Mexico, Nevada, and Utah.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;







&lt;p style="text-align:center;"&gt;&lt;span style="font-size:17pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#6aa84f;"&gt;&lt;strong&gt;Cache Odyssey Regional GeoTours Map&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;



&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com:443/b19ba586-1a55-44b3-8eb2-0781c0a8e99a.jpg" width="100%" /&gt;&lt;/p&gt;






&lt;p&gt;&lt;center&gt;Visit the Cache Odyssey Leaderboard&lt;br /&gt;&lt;a href="https://geocachetalk.com/cache-odyssey-leaderboard/"&gt;&lt;img src="https://img.geocaching.com:443/88d4ab19-c51e-452e-83af-e9e74fbe1bc2.jpg" width="100%" /&gt;&lt;/a&gt;&lt;/center&gt;&lt;/p&gt;
</groundspeak:long_description><groundspeak:encoded_hints>once inside the cache, one of the three numbers will get you into where you need

[when finished, follow the on-site instructions to return everything for the next visitor]</groundspeak:encoded_hints><groundspeak:logs><groundspeak:log id="1361976557"><groundspeak:date>2026-05-18T11:50:00</groundspeak:date><groundspeak:type>Unknown</groundspeak:type><groundspeak:finder id="530518">captainmath</groundspeak:finder><groundspeak:text encoded="false">We need to temporarily disable this geocache. It is not operational at this time. Do not attempt to seek and log this cache right now until I re-enable it and make it available which we trust will be very soon.

In the meantime, remember that this is a letterbox hybrid and as such you need to read and follow the directions to complete this cache. 



</groundspeak:text></groundspeak:log><groundspeak:log id="1361760742"><groundspeak:date>2026-05-16T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="3935130">ted28285</groundspeak:finder><groundspeak:text encoded="false">S and I were starting our journey towards home and made a detour to see if there was a caboose in Hawley. There is in fact a caboose in Hawley. Since we were so close to the odyssey we stopped to sign the logbook. The library was buzzing with users of all ages during our early afternoon visit. Gravity was working slowly today. The inner lock was locked when I opened the box and I didn't know the purpose of that lock until S closed it up. 

Thank you for the cache!</groundspeak:text></groundspeak:log><groundspeak:log id="1361713641"><groundspeak:date>2026-05-16T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="275303">r.e.s.t.seekers</groundspeak:finder><groundspeak:text encoded="false">It was a beautiful spring day, with lots of sunshine.  Ted, RDJ-Pup, and I had visited my sister, C, for her birthday.  Now we stopped here on the way home.  Ted and I took turns waiting in the shade with RDJ-Pup and entering to find the geocache.  The catalogue search rang a bell and I tried to use the information.  It took ted using the code backwards to reveal the log.  When I tried to follow the closing instructions, they didn't quite work.  Clockwise does nothing and ted hadn't done anything to the inner.  The inner is replaced, but the setup needs checked.  </groundspeak:text></groundspeak:log><groundspeak:log id="1361023346"><groundspeak:date>2026-05-14T15:44:44</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="25469529">lindsayasdnil</groundspeak:finder><groundspeak:text encoded="false">Well here MissB and I start our scrapple/williamsburg adventure with cache #3 of the day 
… TFTC and the fun on this one. Enjoying this series </groundspeak:text></groundspeak:log><groundspeak:log id="1363005345"><groundspeak:date>2026-05-14T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="25469328">Missbderycke</groundspeak:finder><groundspeak:text encoded="false">Phone in Airplane Mode, Work Phone &amp; Laptop Shut Off, 5 days. 4 New States. 5 CAAs, 4 Cache Odysseys, 3000+ km driving, 25+km on foot, a lifetime of laughs &amp; memories = priceless. 

Here is a short story long... in booking a hotel in November of 2025 I was asked to stay on the line and listen to an offer. While listening I was getting ready to head out on a hike with a friend so Im not going to lie I was paying zero attention. Afterward the lady was like does that sound good and I answered yes which prompted her to ask for my credit card number. Still not paying attention to what was going on and thinking I was paying for the November hotel I ended up with a 3 night 4 day stay to 11 different locations in the US for a really good deal. When I saw the email stating what I had just signed up for I called lindsayasdnil and said well I did this thing so pick from these 11 locations and we will go on a geotrip! She ended up deciding on Williamsburg, VA as it was one we could drive to and the closest-ish one. Now just to decide when we would go. We seem to like to road trip in May so we decided on doing that again and combine it with a milestone birthday for her. Since my goal is to visit all of the states and also complete this series while doing so we chatted about tacking on an extra day and visiting Delaware as neither of us had it as a state we were planning on visiting for a specific reason (but boy am I sure glad we did, more on this later). About a week before leaving I convinced her that we werent far from the New Jersey CAA either and we would be driving super close to the North Carolina border so we might as well pop down there for a hot minute and grab a cache as well. 

This was the first cache odyssey on our list. We somehow managed to walk past this one multiple times while trying to locate what we needed to get the clue. Took us a bit as we weren't looking in the right section. There was a sweet lady sitting in a chair reading and she was so curious to finally find out what was inside. She asked us a hundred questions and was over the moon to hear about our travels. It's great when people just get right on board instead of looking at us like we are crazy. Fav point on this one for sure such a cool set up. Tftc!</groundspeak:text></groundspeak:log></groundspeak:logs></groundspeak:cache></wpt><wpt lat="40.260683" lon="-74.272983"><time>2024-12-31T00:00:00</time><name>GCAZ2MF</name><desc>Cache Odyssey - New Jersey by nikcap</desc><url>https://www.geocaching.com/geocache/GCAZ2MF</url><urlname>Cache Odyssey - New Jersey</urlname><sym>Geocache</sym><type>Geocache|Letterbox Hybrid</type><groundspeak:cache id="9720377" available="false" archived="false"><groundspeak:name>Cache Odyssey - New Jersey</groundspeak:name><groundspeak:placed_by>nikcap</groundspeak:placed_by><groundspeak:owner id="21194">nikcap</groundspeak:owner><groundspeak:type>Letterbox Hybrid</groundspeak:type><groundspeak:container>Large</groundspeak:container><groundspeak:attributes><groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute><groundspeak:attribute id="6" inc="1">Recommended for kids</groundspeak:attribute><groundspeak:attribute id="1" inc="0">Dogs</groundspeak:attribute><groundspeak:attribute id="67" inc="1">GeoTour</groundspeak:attribute><groundspeak:attribute id="13" inc="0">Available 24/7</groundspeak:attribute><groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute><groundspeak:attribute id="47" inc="1">Field puzzle</groundspeak:attribute><groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute><groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute><groundspeak:attribute id="26" inc="1">Public transportation nearby</groundspeak:attribute><groundspeak:attribute id="15" inc="0">Available in winter</groundspeak:attribute><groundspeak:attribute id="17" inc="0">Poisonous plants</groundspeak:attribute></groundspeak:attributes><groundspeak:difficulty>2</groundspeak:difficulty><groundspeak:terrain>1</groundspeak:terrain><groundspeak:country>United States</groundspeak:country><groundspeak:state>New Jersey</groundspeak:state><groundspeak:short_description /><groundspeak:long_description>&lt;p&gt;&lt;img src="https://img.geocaching.com:443/085ef39f-7673-44fc-945f-3579422587dc.png" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:18px;"&gt;This is a two stage Letterbox Hybrid geocache. Use your GPS to proceed to the posted coordinates. There you will need to search for the instructions to find  the final container that is located within the &lt;a href="https://www.freeholdpubliclibrary.org/"&gt;Freehold Borough Public Library&lt;/a&gt;. The clue is hidden in plain site, but maybe obscured in the late fall or during snow in the winter. &lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:18px;"&gt;This cache is part of the Cache Odyssey Series. The final container holds two stamps, one for the Cache Odyssey passport, and one unique letterbox style stamp of Molly Pitcher at the Battle of Monmouth. Please do not remove either stamp!&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:18px;"&gt;The container is well camoed. &lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:&amp;amp;quot;"&gt;&lt;!--Once you find the container, you will need to solve a simple puzzle/gadget to access the logbook.--&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="background-color:#66ccff;"&gt;This cache is handicap accessible and rated &lt;/span&gt;&lt;/span&gt;&lt;strong&gt;&lt;span style="background-color:#66ccff;"&gt;H11112&lt;/span&gt;&lt;/strong&gt;&lt;br /&gt;
&lt;em&gt;&lt;span style="background-color:#66ccff;"&gt;Less than 500ft. from parking, paved and flat, smooth surface with elevator access and 0ft to 3ft above ground&lt;/span&gt;&lt;/em&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Georgia,serif;"&gt;A big thank you to the library staff, who are happy to host this cache and allowing the placement of this cache. However, the are &amp;quot;sworn to secrecy&amp;quot;. Also, please keep in mind, this is a small library and it&amp;#39;s possible that an event might be taking place in the vacinity of the cache. Please come back in an hour, there is plenty to do in the downtown along with many caches to find.&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:18px;"&gt;Please note the open hours for the library, as the final stage will be found inside the building. The library is close on federal and most state holiday, please verify the opening hours at the&lt;a href="https://www.freeholdpubliclibrary.org/home.php"&gt; library home page&lt;/a&gt; or on &lt;a href="https://www.facebook.com/profile.php?id=100064636394081"&gt;public fb page&lt;/a&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;table class="hours-table__09f24__KR8wh y-css-16hyog2" style="height:401px;width:237px;"&gt;
	&lt;tbody&gt;
		&lt;tr&gt;
			&lt;th scope="col"&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;Mon&lt;/span&gt;&lt;/span&gt;&lt;/th&gt;
			&lt;td&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;9:00 AM - 9:00 PM&lt;/span&gt;&lt;/span&gt;&lt;/td&gt;
		&lt;/tr&gt;
		&lt;tr&gt;
			&lt;th scope="col"&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;Tue&lt;/span&gt;&lt;/span&gt;&lt;/th&gt;
			&lt;td&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;9:00 AM - 9:00 PM&lt;/span&gt;&lt;/span&gt;&lt;/td&gt;
		&lt;/tr&gt;
		&lt;tr&gt;
			&lt;th scope="col"&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;Wed&lt;/span&gt;&lt;/span&gt;&lt;/th&gt;
			&lt;td&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;9:00 AM - 9:00 PM&lt;/span&gt;&lt;/span&gt;&lt;/td&gt;
		&lt;/tr&gt;
		&lt;tr&gt;
		&lt;/tr&gt;
		&lt;tr&gt;
			&lt;th scope="col"&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;Thu&lt;/span&gt;&lt;/span&gt;&lt;/th&gt;
			&lt;td&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;9:00 AM - 5:00 PM&lt;/span&gt;&lt;/span&gt;&lt;/td&gt;
		&lt;/tr&gt;
		&lt;tr&gt;
			&lt;th scope="col"&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;Fri&lt;/span&gt;&lt;/span&gt;&lt;/th&gt;
			&lt;td&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;9:00 AM - 5:00 PM&lt;/span&gt;&lt;/span&gt;&lt;/td&gt;
		&lt;/tr&gt;
		&lt;tr&gt;
			&lt;th scope="col"&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;Sat&lt;/span&gt;&lt;/span&gt;&lt;/th&gt;
			&lt;td&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;9:00 AM - 5:00 PM&lt;/span&gt;&lt;/span&gt;&lt;/td&gt;
		&lt;/tr&gt;
		&lt;tr&gt;
			&lt;th scope="col"&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;Sun&lt;/span&gt;&lt;/span&gt;&lt;/th&gt;
			&lt;td&gt;&lt;span style="font-family:Georgia,serif;"&gt;&lt;span style="font-size:16px;"&gt;Closed&lt;/span&gt;&lt;/span&gt;&lt;/td&gt;

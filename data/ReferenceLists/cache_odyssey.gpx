&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Connecticut, Delaware, Maryland, Maine, Massachusetts, New Hampshire, New Jersey, New York, Pennsylvania, Rhode Island, and Vermont &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;a href="https://coord.info/GT4F0"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alaska, Idaho, Montana, Oregon, Washington, and Wyoming &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;a href="https://coord.info/GT4F2"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;South Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alabama, Arkansas, Florida, Georgia, Louisiana, Mississippi, Oklahoma, South Carolina, and Texas  &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;a href="https://coord.info/GT4EF"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Southwest Region&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt; &lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Arizona, California, Colorado, Hawaii, New Mexico, Nevada, and Utah&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;hr /&gt;
&lt;h2 style="text-align:center;"&gt;&lt;span style="font-size:17pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#6aa84f;"&gt;&lt;strong&gt;Cache Odyssey Regional GeoTours Map&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h2&gt;

&lt;p style="text-align:center;"&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com:443/9513b58f-0611-4f7b-8598-f5b685afca75.png" style="width:500px;" /&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;The Leaderboard!&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:14px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;For all you competitive geocachers who love racing to the finish line, we’ve got something just for you!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:14px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Retired Guy has put together a leaderboard for anyone who starts the journey. &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:14px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to complete their region?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:14px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to find all 50? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:14px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Which cache will receive the most favorite points? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt;&lt;span style="font-size:14px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Click on the Leaderboard button to find out!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="https://geocachetalk.com/cache-odyssey-leaderboard/"&gt;&lt;img src="https://img.geocaching.com:443/88d4ab19-c51e-452e-83af-e9e74fbe1bc2.jpg" style="width:500px;" /&gt;&lt;/a&gt;&lt;/p&gt;
</groundspeak:long_description><groundspeak:encoded_hints>What year did West Virginia join the union?</groundspeak:encoded_hints><groundspeak:logs><groundspeak:log id="1361854656"><groundspeak:date>2026-05-17T17:47:45</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="56569">xrayrepairdude</groundspeak:finder><groundspeak:text encoded="false">On a road trip around the SE. states to do some sightseeing, find States Oldest caches, Cache Odyssey caches, getting counties as needed as we pass through and a long list of other interesting caches all while having a grand adventure as we go!

TFTC, quick find and what a HUGE container filled with all sorts of great swag! This is our 12th Cache Odyssey. FP awarded. 

Thank you Troopbiz for the Letterbox Hybrid cache. This is number 9566 for us. </groundspeak:text></groundspeak:log><groundspeak:log id="1360783559"><groundspeak:date>2026-05-05T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="464158">vaetanone</groundspeak:finder><groundspeak:text encoded="false">A nice park and a good cache.  Quick find.TFTC</groundspeak:text></groundspeak:log><groundspeak:log id="1360341669"><groundspeak:date>2026-05-05T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="831310">Doctor A</groundspeak:finder><groundspeak:text encoded="false">Came here for all the favorite points and it did not disappoint. Tons of swag here. Thanks for another letterbox to my count. #13600</groundspeak:text></groundspeak:log><groundspeak:log id="1359405067"><groundspeak:date>2026-05-05T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="450833">greykitties</groundspeak:finder><groundspeak:text encoded="false">Very easy find at a really nice park. TFTC. #2586</groundspeak:text></groundspeak:log><groundspeak:log id="1358950217"><groundspeak:date>2026-05-03T12:09:01</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="5240023">mimandpap</groundspeak:finder><groundspeak:text encoded="false">On my way home from my HS reunion and grabbed this cache TFTH SL</groundspeak:text></groundspeak:log></groundspeak:logs></groundspeak:cache></wpt><wpt lat="35.630983" lon="-78.9214"><time>2024-10-30T00:00:00</time><name>GCAZTXN</name><desc>Cache Odyssey — North Carolina by ncbiscuit</desc><url>https://www.geocaching.com/geocache/GCAZTXN</url><urlname>Cache Odyssey — North Carolina</urlname><sym>Geocache</sym><type>Geocache|Letterbox Hybrid</type><groundspeak:cache id="9742734" available="true" archived="false"><groundspeak:name>Cache Odyssey — North Carolina</groundspeak:name><groundspeak:placed_by>ncbiscuit</groundspeak:placed_by><groundspeak:owner id="416320">ncbiscuit</groundspeak:owner><groundspeak:type>Letterbox Hybrid</groundspeak:type><groundspeak:container>Large</groundspeak:container><groundspeak:attributes><groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute><groundspeak:attribute id="1" inc="1">Dogs</groundspeak:attribute><groundspeak:attribute id="67" inc="1">GeoTour</groundspeak:attribute><groundspeak:attribute id="13" inc="0">Available 24/7</groundspeak:attribute><groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute><groundspeak:attribute id="32" inc="1">Bicycles</groundspeak:attribute><groundspeak:attribute id="14" inc="0">Recommended at night</groundspeak:attribute><groundspeak:attribute id="40" inc="1">Stealth required</groundspeak:attribute><groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute><groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute></groundspeak:attributes><groundspeak:difficulty>1.5</groundspeak:difficulty><groundspeak:terrain>1</groundspeak:terrain><groundspeak:country>United States</groundspeak:country><groundspeak:state>North Carolina</groundspeak:state><groundspeak:short_description /><groundspeak:long_description>
&lt;p&gt;&lt;img src="https://img.geocaching.com:443/ca87c6ff-e691-4737-b5ca-aaae1d57933b.png" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt;Your odyssey begins at a sign at the bottom of the ramp.&lt;/p&gt;

&lt;p&gt;At this spot you find an oracle that wants to give you some information. &lt;/p&gt;

&lt;p&gt;Happy hunting!&lt;/p&gt;

&lt;p&gt;Harris Lake County Park is open Monday–Sunday, 8 a.m.–Sunset. The park is closed on Thanksgiving Day, Christmas Eve, Christmas Day, and New Year's Day. No searching after hours. 


&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;&lt;img src="https://img.geocaching.com:443/b1b969cc-4176-44a8-ae44-e0438c71e7f1.jpg" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h2&gt;&lt;span style="font-size:23pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Welcome to the Cache Odyssey! &lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h2&gt;

&lt;p&gt; &lt;/p&gt;

&lt;hr /&gt;
&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;What is Cache Odyssey?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Cache Odyssey is a thrilling, nationwide geocaching journey like no other! Conceived by some of the top cache hiders in the U.S., this adventure brings a &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;unique, highly creative letterbox&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; geocache to &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;These caches are designed with &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;everyone in mind&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;—from seasoned explorers to families with kids, and especially those geocaching in wheelchairs. Every cache is built to be fun, imaginative, and 100% &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;accessible&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; to all.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;hr /&gt;
&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Where Can You Find Another One?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Here&amp;#39;s the best part—there&amp;#39;s a Cache Odyssey hide in &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;! That’s right! From coast to coast, every state in America is part of this grand adventure. Once you track down the one closest to you, why stop there?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;This cache is part of the East Central Region Geotour. There are six exciting GeoTours making up this series which include a total of 50 accessible geocaches.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;


&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F3"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;East Central Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Illinois, Indiana, Kentucky, Michigan, North Carolina, Ohio, Tennessee, West Virginia, and Virginia&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F1"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Midwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Iowa, Kansas, Minnesota, Missouri, Nebraska, North Dakota, South Dakota, and Wisconsin &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F4"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northeast Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Connecticut, Delaware, Maryland, Maine, Massachusetts, New Hampshire, New Jersey, New York, Pennsylvania, Rhode Island, and Vermont &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F0"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alaska, Idaho, Montana, Oregon, Washington, and Wyoming &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F2"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;South Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alabama, Arkansas, Florida, Georgia, Louisiana, Mississippi, Oklahoma, South Carolina, and Texas  &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4EF"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Southwest Region&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt; &lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Arizona, California, Colorado, Hawaii, New Mexico, Nevada, and Utah.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:17pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#6aa84f;"&gt;&lt;strong&gt;Cache Odyssey Regional GeoTours Map&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com:443/b19ba586-1a55-44b3-8eb2-0781c0a8e99a.jpg" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;The Leaderboard!&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;For all you competitive geocachers who love racing to the finish line, we’ve got something just for you!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;RetiredGuy has put together a leaderboard for anyone who starts the journey. &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to complete their region?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to find all 50? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Which cache will receive the most favorite points? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Click on the Leaderboard button to find out!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
 &lt;/p&gt;

&lt;p&gt;&lt;a href="https://geocachetalk.com/cache-odyssey-leaderboard/"&gt;&lt;img src="https://img.geocaching.com:443/88d4ab19-c51e-452e-83af-e9e74fbe1bc2.jpg" width="100%" /&gt;&lt;/a&gt;&lt;/p&gt;
&lt;/p&gt;</groundspeak:long_description><groundspeak:encoded_hints>Large and brown. Hard to miss.</groundspeak:encoded_hints><groundspeak:logs><groundspeak:log id="1365020315"><groundspeak:date>2026-06-02T14:52:15</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="5019802">Mazza_</groundspeak:finder><groundspeak:text encoded="false">Nice easy find. Cache is in mostly good shape however I saw a wasp go inside the outer container. So they may be building a nest. I had no issues but future cachers be warned! Thanks!</groundspeak:text></groundspeak:log><groundspeak:log id="1364088955"><groundspeak:date>2026-05-28T16:19:12</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="3100031">Team Michtana</groundspeak:finder><groundspeak:text encoded="false">Super cool cache </groundspeak:text></groundspeak:log><groundspeak:log id="1363813515"><groundspeak:date>2026-05-26T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="5268266">Pine Baron</groundspeak:finder><groundspeak:text encoded="false">5526. Second day heading from GA to NJ with Piglet404 and had this one on the list. First one of the day after a couple hours of travel. Spotted the decal from a distance and opened the cool container. We traded stamps, signed the log and then did some trading. Thanx for the fun Odyssey!</groundspeak:text></groundspeak:log><groundspeak:log id="1363349417"><groundspeak:date>2026-05-22T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="36191060">thatasianpanda</groundspeak:finder><groundspeak:text encoded="false">Quick find. Traded some really cool swag.</groundspeak:text></groundspeak:log><groundspeak:log id="1362141336"><groundspeak:date>2026-05-19T10:25:55</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="4747554">PurpleCatPaws</groundspeak:finder><groundspeak:text encoded="false">Caching with some of my best friends while visiting from CT. This was quick and easy and fun, my favorite!  (Fav added!)  Left loads of swag including a pathtag, handmade earrings, a clown magnet I got in a London thrift store, a purple paw pin, a cat keychain, and a PEZ dispenser. Didn’t see any travel bugs but dropped a couple. TFTC!  :D </groundspeak:text></groundspeak:log></groundspeak:logs></groundspeak:cache></wpt><wpt lat="28.62365" lon="-81.36565"><time>2024-11-09T00:00:00</time><name>GCB06W5</name><desc>Cache Odyssey - Florida by BnJBish &amp; MaitlandLibrary</desc><url>https://www.geocaching.com/geocache/GCB06W5</url><urlname>Cache Odyssey - Florida</urlname><sym>Geocache</sym><type>Geocache|Letterbox Hybrid</type><groundspeak:cache id="9754219" available="true" archived="false"><groundspeak:name>Cache Odyssey - Florida</groundspeak:name><groundspeak:placed_by>BnJBish &amp; MaitlandLibrary</groundspeak:placed_by><groundspeak:owner id="6276586">BnJBish</groundspeak:owner><groundspeak:type>Letterbox Hybrid</groundspeak:type><groundspeak:container>Regular</groundspeak:container><groundspeak:attributes><groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute><groundspeak:attribute id="6" inc="1">Recommended for kids</groundspeak:attribute><groundspeak:attribute id="41" inc="1">Stroller accessible</groundspeak:attribute><groundspeak:attribute id="67" inc="1">GeoTour</groundspeak:attribute><groundspeak:attribute id="13" inc="0">Available 24/7</groundspeak:attribute><groundspeak:attribute id="7" inc="1">Takes less than one hour</groundspeak:attribute><groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute><groundspeak:attribute id="47" inc="1">Field puzzle</groundspeak:attribute><groundspeak:attribute id="52" inc="0">Night cache</groundspeak:attribute><groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute><groundspeak:attribute id="30" inc="1">Picnic tables nearby</groundspeak:attribute><groundspeak:attribute id="26" inc="1">Public transportation nearby</groundspeak:attribute><groundspeak:attribute id="33" inc="1">Motorcycles</groundspeak:attribute><groundspeak:attribute id="46" inc="1">Trucks/RVs</groundspeak:attribute></groundspeak:attributes><groundspeak:difficulty>2</groundspeak:difficulty><groundspeak:terrain>1</groundspeak:terrain><groundspeak:country>United States</groundspeak:country><groundspeak:state>Florida</groundspeak:state><groundspeak:short_description /><groundspeak:long_description>&lt;p&gt;&lt;img src="https://img.geocaching.com:443/078c6545-c107-4d96-b1de-870b357c26ad.png" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
 &lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;Welcome to Cache Odyssey - Florida!&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;This cache is only available during the following hours. Be aware that holiday availability may differ.  (The cache was relocated on April 20, 2026. The following description reflects the current location.)&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="margin-left:48px;"&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;Sunday                         1:00pm - 6:00pm&lt;br /&gt;
Monday-Thursday       10:00am - 9:00pm&lt;br /&gt;
Friday-Saturday           10:00am - 6:00pm&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;The geocache you seek is not at the posted coordinates, but you should begin there. &lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;Florida has always had a rich history of conservation. Much of it started with the help of one woman – Clara Dommerich.&lt;br /&gt;
&lt;br /&gt;
Mrs. Dommerich was one of the original Florida “Snow Birds”. She lived in New York, but would spend summers here in Maitland, FL. In 1896 she donated a collection of 360 books that would eventually evolve into the library you see before you. In 1907, these doors opened for the first time, inviting residents into a world of imagination and education, with a legacy spanning 130 years at the heart of the community.  &lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;&lt;strong&gt;From this point, please travel 84 ft North, then 75 ft West. From there, make your way 116 ft South. &lt;/strong&gt;–&lt;em&gt; Do not cross the street. Do not cross the train tracks.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;In those 9 years in between her donation, and the opening of the &amp;quot;new&amp;quot; library, Mrs. Dommerich engaged in some other “snow bird” related pursuits. Namely, the protection of the several wading birds that had been hunted to near extinction.&lt;br /&gt;
&lt;br /&gt;
Organized by Mrs. Dommerich, the first Florida chapter of the Audubon Society met to discuss how to stop the decimation of these bird colonies, specifically the Snowy White Egret, whose beautiful plumage was highly prized by women’s hatmakers.&lt;br /&gt;
&lt;br /&gt;
Nearby, you will find a birdbath dedicated to this group, and later donated to the library, when the original Dommerich Estate was dissolved in the 1950’s. &lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;Read the inscription on the birdbath to find the following information.&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;*THE FLORIDA &lt;strong&gt;&lt;span style="background-color:#e74c3c;"&gt;_ _ _&lt;/span&gt;&lt;/strong&gt;XXXX SOCIETY WAS &lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;FOUNDED BY CLARA J &lt;strong&gt;&lt;span style="background-color:#f1c40f;"&gt;_ _ _&lt;/span&gt;&lt;/strong&gt;XXXXXX AND LOUIS F &lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;DOMM&lt;strong&gt;&lt;u&gt;&lt;span style="background-color:#66ffcc;"&gt;X&lt;/span&gt;&lt;/u&gt;&lt;/strong&gt;R&lt;strong&gt;&lt;u&gt;&lt;span style="background-color:#66ffcc;"&gt;X&lt;/span&gt;&lt;/u&gt;&lt;/strong&gt;CH AT &lt;strong&gt;&lt;u&gt;&lt;span style="background-color:#66ffcc;"&gt;X&lt;/span&gt;&lt;/u&gt;&lt;/strong&gt;IAWATHA GROVE ON MAR&lt;strong&gt;&lt;u&gt;&lt;span style="background-color:#66ffcc;"&gt;X&lt;/span&gt;&lt;/u&gt;&lt;/strong&gt;H 2ND 1900&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
 &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;&lt;span style="background-color:#e74c3c;"&gt;(&lt;strong&gt;_ _ _&lt;/strong&gt;)&lt;/span&gt;&lt;br /&gt;
&lt;strong&gt;*&lt;span style="background-color:#66ffcc;"&gt;(&lt;/span&gt;&lt;u&gt;&lt;span style="background-color:#66ffcc;"&gt;_ _ _._)&lt;/span&gt;&lt;/u&gt;*&lt;/strong&gt;&lt;br /&gt;
&lt;span style="background-color:#f1c40f;"&gt;(&lt;strong&gt;_ _ _&lt;/strong&gt;)&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;br /&gt;
 &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;Today, the library houses a special collection of books, donated with this significant legacy in mind. It can be found inside, in the Adult Non-Fiction wing of the library, cataloged as the &lt;u&gt;&lt;strong&gt;Audubon Collection&lt;/strong&gt;&lt;/u&gt;.&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;You should now have all the information you need to find the cache. Please be mindful of the quiet spaces while searching for the cache. Remember that the stamp inside is not to be removed, and should not be used to stamp anything other than your passport or your personal letterbox journal.&lt;br /&gt;
&lt;br /&gt;
Thank you for spending your time here at the Maitland Public Library, and for supporting the Cache Odyssey endeavor to provide interesting and accessible letterboxes in every state.&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt; &lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:12pt;"&gt;&lt;span style="font-family:Aptos,sans-serif;"&gt;&lt;em&gt;Placed with permission from the library’s director and maintained by the library’s program coordinator.&lt;/em&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
 &lt;/p&gt;

&lt;p&gt;&lt;a href="https://geocachetalk.com/wp-content/uploads/2024/12/Cache-Odyssey-South-GeoTour-Passport.pdf"&gt;Dowload your Cache Odyssey - South Region GeoTour Passport here.&lt;/a&gt;&lt;br /&gt;
&lt;br /&gt;
&lt;br /&gt;
&lt;span style="font-size:20px;"&gt;Congratulations to Buckeyecacher111 on the FTF! Enjoy the Odyssey!!&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;&lt;img src="https://img.geocaching.com:443/b1b969cc-4176-44a8-ae44-e0438c71e7f1.jpg" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h2&gt;&lt;span style="font-size:23pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Welcome to the Cache Odyssey! &lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h2&gt;

&lt;p&gt; &lt;/p&gt;

&lt;hr /&gt;
&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;What is Cache Odyssey?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Cache Odyssey is a thrilling, nationwide geocaching journey like no other! Conceived by some of the top cache hiders in the U.S., this adventure brings a &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;unique, highly creative letterbox&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; geocache to &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;These caches are designed with &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;everyone in mind&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;—from seasoned explorers to families with kids, and especially those geocaching in wheelchairs. Every cache is built to be fun, imaginative, and 100% &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;accessible&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; to all.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;hr /&gt;
&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Where Can You Find Another One?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Here&amp;#39;s the best part—there&amp;#39;s a Cache Odyssey hide in &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;! That’s right! From coast to coast, every state in America is part of this grand adventure. Once you track down the one closest to you, why stop there?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;This cache is part of the South Region Geotour. There are six exciting GeoTours making up this series which include a total of 50 accessible geocaches.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F3"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;East Central Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Illinois, Indiana, Kentucky, Michigan, North Carolina, Ohio, Tennessee, West Virginia, and Virginia&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F1"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Midwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Iowa, Kansas, Minnesota, Missouri, Nebraska, North Dakota, South Dakota, and Wisconsin &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F4"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northeast Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Connecticut, Delaware, Maryland, Maine, Massachusetts, New Hampshire, New Jersey, New York, Pennsylvania, Rhode Island, and Vermont &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F0"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alaska, Idaho, Montana, Oregon, Washington, and Wyoming &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F2"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;South Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alabama, Arkansas, Florida, Georgia, Louisiana, Mississippi, Oklahoma, South Carolina, and Texas  &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4EF"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Southwest Region&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt; &lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Arizona, California, Colorado, Hawaii, New Mexico, Nevada, and Utah.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:17pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#6aa84f;"&gt;&lt;strong&gt;Cache Odyssey Regional GeoTours Map&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com:443/b19ba586-1a55-44b3-8eb2-0781c0a8e99a.jpg" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;The Leaderboard!&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;For all you competitive geocachers who love racing to the finish line, we’ve got something just for you!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;RetiredGuy has put together a leaderboard for anyone who starts the journey. &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to complete their region?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to find all 50? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Which cache will receive the most favorite points? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Click on the Leaderboard button to find out!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
 &lt;/p&gt;

&lt;p&gt;&lt;a href="https://geocachetalk.com/cache-odyssey-leaderboard/"&gt;&lt;img src="https://img.geocaching.com:443/88d4ab19-c51e-452e-83af-e9e74fbe1bc2.jpg" width="100%" /&gt;&lt;/a&gt;&lt;/p&gt;
</groundspeak:long_description><groundspeak:encoded_hints>Puzzle Clue: For GREEN -  A=1, B=2, C=3
Hide Clue: What would Lavar Burton or Mychal Threets suggest you do? "Take a look.. it's in....."</groundspeak:encoded_hints><groundspeak:logs><groundspeak:log id="1363293819"><groundspeak:date>2026-05-24T15:35:11</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="5805495">Scooby Patrol</groundspeak:finder><groundspeak:text encoded="false">Great hide and great new spot for this one!  Fav point for sure. 

Scoobs
</groundspeak:text></groundspeak:log><groundspeak:log id="1362833092"><groundspeak:date>2026-05-22T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="11181996">DTCharlie</groundspeak:finder><groundspeak:text encoded="false">On a week, long trip from Northeast Pennsylvania to Southern Florida. Visiting family, having adventure and finding two cashes. The the Odyssey to cash is there something that I have been targeting. Happy to check this one off the box, but it was not easy to do. First of all I couldn’t find the burp bath. Lol. It was right where it was supposed to be, but it was hiding from me. luckily one of the friendly librarians I helped me out. Then the app I use, did not show the information correctly so I had no idea what to do with the information. Messaged my daughter and she figured out what the problem was. Then I finally had the geocache in hand. this one was definitely an adventure. It’s good to get a favorite point.</groundspeak:text></groundspeak:log><groundspeak:log id="1361234007"><groundspeak:date>2026-05-15T17:28:18</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="55200772">xyesol</groundspeak:finder><groundspeak:text encoded="false">Thanks for the find!</groundspeak:text></groundspeak:log><groundspeak:log id="1361232341"><groundspeak:date>2026-05-15T17:17:45</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="36191565">Emily9351</groundspeak:finder><groundspeak:text encoded="false">Thanks!!</groundspeak:text></groundspeak:log><groundspeak:log id="1360574656"><groundspeak:date>2026-05-12T12:00:00</groundspeak:date><groundspeak:type>Write note</groundspeak:type><groundspeak:finder id="6276586">BnJBish</groundspeak:finder><groundspeak:text encoded="false">Did a trackable drop. All is well!

We began caching back on August 19, 2012, while trying to find something inexpensive to do for J's 30th birthday. Since then, we have streaked for 539 days, cached all 50 US States, 2 Canadian provinces, Mexico, France, and UK. We have 21 State's oldest and the oldest in BC, Canada. We have attended 12 Megas, 2 Gigas, and 2 Block Parties! We were honored to be a part of Cache Odyssey, hiding Florida's, and finding 14 others! We have all the Florida counties and Delorme and have county connected Florida to Rome, Memphis, and Tulsa. We are looking forward to many more adventures to come. We want to thank all of the cache owners who have put these caches out for us to find. Without you, this game would not exist. 

May 12, 2026 10:52 AM 6498

One step closer to that realization that "Free Will" is just a fridge magnet, and we live briefly in a cold, unfeeling, deterministic universe in an abandoned warehouse called time....

Ah. Geocaching.

KUNGALOOSH!</groundspeak:text></groundspeak:log></groundspeak:logs></groundspeak:cache></wpt><wpt lat="46.611883" lon="-111.989"><time>2024-12-29T00:00:00</time><name>GCB06CE</name><desc>Cache Odyssey - Montana by Danero1919</desc><url>https://www.geocaching.com/geocache/GCB06CE</url><urlname>Cache Odyssey - Montana</urlname><sym>Geocache</sym><type>Geocache|Letterbox Hybrid</type><groundspeak:cache id="9753763" available="true" archived="false"><groundspeak:name>Cache Odyssey - Montana</groundspeak:name><groundspeak:placed_by>Danero1919</groundspeak:placed_by><groundspeak:owner id="18610125">Danero1919</groundspeak:owner><groundspeak:type>Letterbox Hybrid</groundspeak:type><groundspeak:container>Large</groundspeak:container><groundspeak:attributes><groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute><groundspeak:attribute id="41" inc="1">Stroller accessible</groundspeak:attribute><groundspeak:attribute id="1" inc="0">Dogs</groundspeak:attribute><groundspeak:attribute id="67" inc="1">GeoTour</groundspeak:attribute><groundspeak:attribute id="13" inc="0">Available 24/7</groundspeak:attribute><groundspeak:attribute id="53" inc="1">Park and grab</groundspeak:attribute><groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute><groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute><groundspeak:attribute id="59" inc="1">Food nearby</groundspeak:attribute><groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute><groundspeak:attribute id="26" inc="1">Public transportation nearby</groundspeak:attribute><groundspeak:attribute id="29" inc="1">Telephone nearby</groundspeak:attribute><groundspeak:attribute id="15" inc="1">Available in winter</groundspeak:attribute></groundspeak:attributes><groundspeak:difficulty>3</groundspeak:difficulty><groundspeak:terrain>1</groundspeak:terrain><groundspeak:country>United States</groundspeak:country><groundspeak:state>Montana</groundspeak:state><groundspeak:short_description /><groundspeak:long_description>&lt;p&gt;&lt;img src="https://img.geocaching.com:443/81da709c-264b-4f44-9ec4-01116521d8bb.png" width="100%" /&gt;&lt;/p&gt;

&lt;h1&gt; &lt;/h1&gt;

&lt;h1&gt;Welcome to Montana!&lt;/h1&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;You&amp;#39;re in Big Sky Country - a varied landscape of rolling hills, steep mountains, deep valleys, and everything in between. Montana is filled with all manner of wildlife and people from all walks of life. No matter what you like to do outside, you can do it here in Montana. There are millions of  reasons people fall in love with the Treasure State. &lt;/p&gt;

&lt;p&gt;The Montana hide for the Cache Odyssey GeoTour (&lt;em&gt;more details below)&lt;/em&gt; is located in none other than Helena, MT, the capital city. Helena has its roots in the gold rush days of the 1860s, as gold was discovered by four gentlemen along what became known as Last Chance Gulch. The vast store of gold was enough for many to stake their claim, and the town grew to over 3,000 people in just a few years. The arrival of the railroad and the declaration of Helena as the territorial capital in subsequent decades helped ensure the longevity of the town&amp;#39;s prosperity, even as the gold was running dry. By 1888, Helena was home to some 50 millionaires, whose wealth is apparent in the lasting architecture seen downtown. Last Chance Gulch ultimately produced around $3.6 billion worth of gold in today&amp;#39;s dollars. After the gold rush, Helena&amp;#39;s central location provided useful for assisting with the transport and distribution of raw materials and goods from other nearby extraction industries. Agriculture in the area also helped keep the growth of the town sustainable. &lt;em&gt;(More on the &lt;a href="https://helenacollege.edu/catalog/helenahistory.aspx"&gt;history of Helena&lt;/a&gt;)&lt;/em&gt;&lt;/p&gt;

&lt;p&gt;Today, Helena remains a diverse and thriving community of people who love and care for the valley they call home. &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h1&gt;The Cache&lt;/h1&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;The Montana Cache Odyssey hide is located at the Helena Forest Service office, a place which welcomes everyone. This quaint location contains various rustic displays which provide a sample of what makes Montana unique. While the location is not quite a visitors center, it does have lots of information about the Helena-Lewis and Clark National Forest. &lt;u&gt;Since this is considered a federal building, there are a few important rules which &lt;strong&gt;must be followed:&lt;/strong&gt;&lt;/u&gt;&lt;/p&gt;

&lt;ul style="list-style-type:disc;"&gt;
	&lt;li&gt;&lt;strong&gt;No loitering or disorderly conduct, nor soliciting or distributing materials.&lt;/strong&gt;&lt;/li&gt;
	&lt;li&gt;&lt;strong&gt;Gambling, drugs, alcohol, explosives, and weapons are all prohibited in the building.&lt;/strong&gt;&lt;/li&gt;
	&lt;li&gt;&lt;strong&gt;Only seeing-eye/guide dogs allowed inside.&lt;/strong&gt;&lt;/li&gt;
	&lt;li&gt;&lt;a href="https://www.gsa.gov/system/files/GSA_Rules_Reg_1105.pdf"&gt;Additional rules and regulations governing conduct on federal property.&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;h3&gt; &lt;/h3&gt;

&lt;h2&gt;&lt;strong&gt;Cache is available Monday through Friday from 8:00 am to 4:00 pm MST, excluding &lt;a href="https://s3.amazonaws.com/gs-geo-images/9d59399f-7f10-45cc-b241-80c98a41a9a4_l.jpg"&gt;federal holidays&lt;/a&gt;.&lt;/strong&gt;&lt;/h2&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:16px;"&gt;&lt;u&gt;&lt;strong&gt;Stage One&lt;/strong&gt;&lt;/u&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;At the posted coord&lt;span style="font-size:12px;"&gt;inates, y&lt;/span&gt;ou will find a placard on a large rock, which you will need to view to determine the combination of the lock on the cache container.  &lt;/p&gt;

&lt;p style="text-align:center;"&gt; &lt;span style="font-size:16px;"&gt;&lt;strong&gt;Somewhere on the placard is the date &amp;quot;May AB, CDEF&amp;quot;&lt;/strong&gt;&lt;/span&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:16px;"&gt;&lt;strong&gt;Lock combination: CBBE&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:16px;"&gt;&lt;u&gt;&lt;strong&gt;Stage Two&lt;/strong&gt;&lt;/u&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;The cache is located in the main lobby, and is near the listed waypoint. You do not need to speak with someone at the desk to find the cache. As a letterbox hybrid, this cache contains a stamp; in fact, the cache contains two unique stamps! Please leave both stamps in the cache, along with the provided ink pad. There are slips of paper in the cache so that you can stamp a page and take it with you if you would like. This cache is starting with a whole bunch of Montana themed swag; please trade up or trade even. &lt;/p&gt;

&lt;p&gt;&lt;em&gt;Congrats to MontanaDerik, MTBreeze, and MagentaNickles for the co-FTF!&lt;/em&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h1&gt;Notable Places to Visit&lt;/h1&gt;

&lt;p&gt; &lt;/p&gt;

&lt;ul&gt;
	&lt;li&gt;Along historic Last Chance Gulch, you can find the walking mall. This unique and wheelchair accessible experience draws together a myriad of interests from classic architecture and statues to modern art and thriving local business. &lt;/li&gt;
	&lt;li&gt;On Capital Hill you can find the capitol building of Montana, whose halls are filled with brilliant artwork and many celebrations of Montana&amp;#39;s rich history.&lt;/li&gt;
	&lt;li&gt;You can find many gorgeous Victorian homes downtown, including the original governor&amp;#39;s mansion, which offers tours.&lt;/li&gt;
	&lt;li&gt;On the east edge of town, you can find the Archie Bray Foundation. This multi use facility that has several acres of larger-than-life clay and mixed media artworks, which can be toured for free year-round. &lt;/li&gt;
	&lt;li&gt;Mount Helena is one of the most popular hiking destinations in the area, in part because it offers clear views of the city and surrounding valley. &lt;/li&gt;
	&lt;li&gt;A few miles west of town, you can find Two Camps Vista. This scenic and wheelchair friendly location offers a self guided tour about the history of the Lewis and Clark expedition. Please exercise caution if visiting during the winter months. &lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h1&gt; &lt;/h1&gt;

&lt;h1&gt;Notable Geocaches in the Area&lt;/h1&gt;

&lt;p&gt; &lt;/p&gt;

&lt;ul&gt;
	&lt;li&gt;The two oldest active caches in Montana are within a 90 minute drive of Helena - &lt;a href="https://www.geocaching.com/geocache/GC493_missouri-headwaters"&gt;GC493 Missouri Headwaters&lt;/a&gt; and &lt;a href="https://www.geocaching.com/geocache/GC492_fairweather"&gt;GC492 Fairweather&lt;/a&gt; (fair roads, approach from Three Forks, NOT Toston)&lt;/li&gt;
	&lt;li&gt;There are several 2001 geocaches within an hour drive of Helena. &lt;a href="https://www.geocaching.com/geocache/GC544"&gt;GC544 bird paradise&lt;/a&gt; and &lt;a href="https://www.geocaching.com/geocache/GC17B0"&gt;GC17B0 Hell&amp;#39;s Gate&lt;/a&gt; (fair roads), as well as &lt;a href="https://www.geocaching.com/geocache/GC6E8_copper-city-overlook"&gt;GC6E8 Copper City Overlook&lt;/a&gt; and &lt;a href="https://www.geocaching.com/geocache/GC543_cliffview"&gt;GC543 cliffview&lt;/a&gt; (rougher back roads, high clearance and/or four wheel drive vehicle recommended).&lt;/li&gt;
	&lt;li&gt;The Montana Cache Across America &lt;a href="https://www.geocaching.com/geocache/GC1272W"&gt;GC1272W&lt;/a&gt; is located 20 miles northeast of here (this is a serious uphill scramble and is not winter friendly).&lt;/li&gt;
	&lt;li&gt;Helena used to have a GeoTour; here&amp;#39;s a list of &lt;a href="https://coord.info/BME18BT"&gt;active caches from the Helena GeoExpedition&lt;/a&gt;. &lt;/li&gt;
	&lt;li&gt;There are a variety of geocache types in the Helena area including Letterboxes, Wherigos, Earthcaches, Challenges, Night Caches and even a few Virtuals. &lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;&lt;img src="https://img.geocaching.com:443/b1b969cc-4176-44a8-ae44-e0438c71e7f1.jpg" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h2&gt;&lt;span style="font-size:23pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Welcome to the Cache Odyssey! &lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h2&gt;

&lt;p&gt; &lt;/p&gt;

&lt;hr /&gt;
&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;What is Cache Odyssey?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Cache Odyssey is a thrilling, nationwide geocaching journey like no other! Conceived by some of the top cache hiders in the U.S., this adventure brings a &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;unique, highly creative letterbox&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; geocache to &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;These caches are designed with &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;everyone in mind&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;—from seasoned explorers to families with kids, and especially those geocaching in wheelchairs. Every cache is built to be fun, imaginative, and 100% &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;accessible&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; to all.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;hr /&gt;
&lt;p&gt; &lt;/p&gt;

&lt;h3&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Where Can You Find Another One?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h3&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Here&amp;#39;s the best part—there&amp;#39;s a Cache Odyssey hide in &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;! That’s right! From coast to coast, every state in America is part of this grand adventure. Once you track down the one closest to you, why stop there?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;This cache is part of the Northwest Region Geotour. There are six exciting GeoTours making up this series which include a total of 50 accessible geocaches.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F3"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;East Central Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Illinois, Indiana, Kentucky, Michigan, North Carolina, Ohio, Tennessee, West Virginia, and Virginia&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F1"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Midwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Iowa, Kansas, Minnesota, Missouri, Nebraska, North Dakota, South Dakota, and Wisconsin &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F4"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northeast Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Connecticut, Delaware, Maryland, Maine, Massachusetts, New Hampshire, New Jersey, New York, Pennsylvania, Rhode Island, and Vermont &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F0"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Northwest Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alaska, Idaho, Montana, Oregon, Washington, and Wyoming &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4F2"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;South Region GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Alabama, Arkansas, Florida, Georgia, Louisiana, Mississippi, Oklahoma, South Carolina, and Texas  &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;u&gt;&lt;a href="https://coord.info/GT4EF"&gt;&lt;span style="color:#3498db;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;Southwest Region&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt; &lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;strong&gt;GeoTour&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/a&gt;&lt;/u&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Arizona, California, Colorado, Hawaii, New Mexico, Nevada, and Utah.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:17pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#6aa84f;"&gt;&lt;strong&gt;Cache Odyssey Regional GeoTours Map&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com:443/b19ba586-1a55-44b3-8eb2-0781c0a8e99a.jpg" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;The Leaderboard!&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;For all you competitive geocachers who love racing to the finish line, we’ve got something just for you!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;RetiredGuy has put together a leaderboard for anyone who starts the journey. &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to complete their region?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Who will be the first to find all 50? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
	&lt;li style="list-style-type:disc;"&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Which cache will receive the most favorite points? &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt;&lt;span style="font-size:16px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#000000;"&gt;Click on the Leaderboard button to find out!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
 &lt;/p&gt;

&lt;p&gt;&lt;a href="https://geocachetalk.com/cache-odyssey-leaderboard/"&gt;&lt;img src="https://img.geocaching.com:443/88d4ab19-c51e-452e-83af-e9e74fbe1bc2.jpg" width="100%" /&gt;&lt;/a&gt;&lt;/p&gt;
</groundspeak:long_description><groundspeak:encoded_hints>Check the description for hours when the cache is available and rules regarding the location. Make sure to get the combination to the lock before searching. You do not need to talk to a staff member to find the cache.</groundspeak:encoded_hints><groundspeak:logs><groundspeak:log id="1363951084"><groundspeak:date>2026-05-27T15:34:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="8814283">TheLF</groundspeak:finder><groundspeak:text encoded="false">Continuing my Odyssey quest after GeoWoodstock in Hutchinson, KS. I may get home in 3 weeks, and then again, I may not. I’m a geocacher and retired.😎.  This is my 41st Odyssey cache.
**********
Arrived just before closing time. Great skill was used to build this host. It will get a favorite point 😎.
Everything worked as expected and I found and discovered 14 travel bugs in the cache. There were 17 listed on the cache page..! Hopefully the logging will catch up soon.
I’d like to know where the little bear pen came from..😎.   I know a few geocaches in Florida that would like to have a pen like that !❤️
The cache, the host, and all the contents are in great shape. Thanks for being a part of the Odyssey series and choosing this location. I spent a few minutes talking with the gentleman at the front desk and learned some things .  I’m The Little Fishermasn and I guess we all “fish” for some information every day..😂. Did you catch that CaptainMath…????</groundspeak:text></groundspeak:log><groundspeak:log id="1363944196"><groundspeak:date>2026-05-27T15:03:34</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="887579">dukemartin</groundspeak:finder><groundspeak:text encoded="false">Found it with Paintedwarrior and quadguy47.  Thanks for the cache. </groundspeak:text></groundspeak:log><groundspeak:log id="1363924574"><groundspeak:date>2026-05-27T13:05:40</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="4051795">quadguy47</groundspeak:finder><groundspeak:text encoded="false">caching trip with dukemartin and painted warrior. TFTC</groundspeak:text></groundspeak:log><groundspeak:log id="1363923646"><groundspeak:date>2026-05-27T12:57:19</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="1454863">Paintedwarrior</groundspeak:finder><groundspeak:text encoded="false">Traveled up from Yellowstone to get Montana’s odyssey. Beautiful day, pretty views. Great day to geocache. TFTC. </groundspeak:text></groundspeak:log><groundspeak:log id="1364235797"><groundspeak:date>2026-05-18T19:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="10594955">Skyhawker</groundspeak:finder><groundspeak:text encoded="false">Day 2 - PeachofWA and I are on our way from Seattle to Hutchinson, KS for Geowoodstock XXII. Another long day. Started off this morning with the Cache Odyssey Cache - Montana at the Helena library. Then headed straight south logging counties on the way to West Yellowstone. Virtual and Earthcaches through Yellowstone, and out the East entrance to Cody and eventually stopped in Greybull. PeachofWA finally has caches in Wyoming. Tomorrow - Sheridan to Devils Tower and then Cheyenne. Thanks to all the COs for placing these. SL. TFTC.</groundspeak:text></groundspeak:log></groundspeak:logs></groundspeak:cache></wpt><wpt lat="42.445067" lon="-79.3343"><time>2024-11-17T00:00:00</time><name>GCB0FK9</name><desc>Cache Odyssey - New York  by The Pizza Ninja 🍕🥷</desc><url>https://www.geocaching.com/geocache/GCB0FK9</url><urlname>Cache Odyssey - New York </urlname><sym>Geocache</sym><type>Geocache|Letterbox Hybrid</type><groundspeak:cache id="9762624" available="true" archived="false"><groundspeak:name>Cache Odyssey - New York </groundspeak:name><groundspeak:placed_by>The Pizza Ninja 🍕🥷</groundspeak:placed_by><groundspeak:owner id="12360509">The Pizza Ninja</groundspeak:owner><groundspeak:type>Letterbox Hybrid</groundspeak:type><groundspeak:container>Regular</groundspeak:container><groundspeak:attributes><groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute><groundspeak:attribute id="6" inc="1">Recommended for kids</groundspeak:attribute><groundspeak:attribute id="41" inc="1">Stroller accessible</groundspeak:attribute><groundspeak:attribute id="1" inc="1">Dogs</groundspeak:attribute><groundspeak:attribute id="67" inc="1">GeoTour</groundspeak:attribute><groundspeak:attribute id="7" inc="1">Takes less than one hour</groundspeak:attribute><groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute><groundspeak:attribute id="65" inc="1">Yard (private residence)</groundspeak:attribute><groundspeak:attribute id="32" inc="1">Bicycles</groundspeak:attribute><groundspeak:attribute id="52" inc="0">Night cache</groundspeak:attribute><groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute><groundspeak:attribute id="59" inc="1">Food nearby</groundspeak:attribute><groundspeak:attribute id="33" inc="1">Motorcycles</groundspeak:attribute><groundspeak:attribute id="34" inc="0">Quads</groundspeak:attribute><groundspeak:attribute id="15" inc="1">Available in winter</groundspeak:attribute><groundspeak:attribute id="36" inc="0">Snowmobiles</groundspeak:attribute></groundspeak:attributes><groundspeak:difficulty>2.5</groundspeak:difficulty><groundspeak:terrain>1</groundspeak:terrain><groundspeak:country>United States</groundspeak:country><groundspeak:state>New York</groundspeak:state><groundspeak:short_description /><groundspeak:long_description>&lt;p&gt;&lt;img src="https://img.geocaching.com:443/085ef39f-7673-44fc-945f-3579422587dc.png" width="100%" /&gt;&lt;/p&gt;

&lt;p&gt;This Geocache is not at the posted coordinates.&lt;/p&gt;

&lt;p&gt;&lt;strong&gt;It has been placed with the permission of the property owners. Please feel free to park nearby the coordinates provided through Certitude. &lt;/strong&gt;&lt;/p&gt;

&lt;p&gt;In order to get the coordinates of the Geocache you will need to go to the posted coordinates and look for a circular sign with a ten letter word. Then, enter in the answer in Certitude. &lt;/p&gt;

&lt;div style="text-align:center;"&gt;&lt;a href="https://www.certitudes.org/certitude?wp=GCB0FK9"&gt;&lt;img src="https://www.certitudes.org/logo?wp=GCB0FK9" title="Click to see the list of solvers" /&gt;&lt;/a&gt;

&lt;div style="font-family:Comic Sans MS;"&gt;You can validate your puzzle solution with &lt;a href="https://www.certitudes.org/certitude?wp=GCB0FK9"&gt;certitude&lt;/a&gt;.&lt;/div&gt;
&lt;/div&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;This is a letterbox hybrid geocache containing the Cache Odyssey New York self-inking stamp, a stamp pad, and a logbook. If you have a personal stamp, please stamp the logbook with your stamp. You can just sign the logbook if you don&amp;#39;t have a personal stamp. The stamp and logbook remain in the letterbox hybrid for the next visitor to use.&lt;/p&gt;

&lt;hr /&gt;
&lt;h2&gt;Welcome to Fredonia, NY!&lt;/h2&gt;

&lt;h2&gt;The village has a rich and fascinating history:&lt;/h2&gt;

&lt;ul&gt;
	&lt;li&gt;The village that is now Fredonia was most likely first occupied by early Mound Builders, then the Erie people (13th to 17th centuries), and then the Iroquois.&lt;/li&gt;
	&lt;li&gt;Fredonia is notable for being the site of the first natural gas well used for illumination in the United States, drilled in 1825. &lt;/li&gt;
	&lt;li&gt;The first Farmer’s Grange in the country was built in Fredonia in 1868.&lt;/li&gt;
	&lt;li&gt;The first meeting of the Woman&amp;#39;s Christian Temperance Union (WCTU) was held in Fredonia in 1873. The organization became influential in advocating for social reforms such as prohibition.&lt;/li&gt;
	&lt;li&gt;Mark Twain had a very enjoyable lecture at Fredonia, and his family then moved to Fredonia where his niece married Charles Webster. The Charles Webster Publishing Company published the Adventures of Huckleberry Finn (1885) and the Personal Memoirs of Ulysses S. Grant (1885).&lt;/li&gt;
	&lt;li&gt;The Buffalo Braves (currently named the Los Angeles Clippers) held their training camps at Fredonia.&lt;/li&gt;
	&lt;li&gt;The Buffalo Bills held their training camp in Fredonia until 2000. During that time, they went to 4 consecutive Superbowls. &lt;/li&gt;
	&lt;li&gt;2012 Olympic Pole Vaulter Gold Medalist Jenn Suhr was born in Fredonia. A member of team The Pizza Ninja was on the Track Team with Jenn in High School. &lt;br /&gt;
	 &lt;/li&gt;
&lt;/ul&gt;

&lt;hr /&gt;
&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com:443/b1b969cc-4176-44a8-ae44-e0438c71e7f1.jpg" style="width:80%;" /&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:23pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Welcome to the Cache Odyssey! &lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;hr /&gt;
&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;What is Cache Odyssey?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Cache Odyssey is a thrilling, nationwide geocaching journey like no other! Conceived by some of the top cache hiders in the U.S., this adventure brings a &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;unique, highly creative letterbox&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; geocache to &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;These caches are designed with &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;everyone in mind&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;—from seasoned explorers to families with kids, and especially those geocaching in wheelchairs. Every cache is built to be fun, imaginative, and 100% &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;accessible&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt; to all.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;Where Can You Find Another One?&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;Here&amp;#39;s the best part—there&amp;#39;s a Cache Odyssey hide in &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;&lt;strong&gt;every state&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;! That’s right! From coast to coast, every state in America is part of this grand adventure. Once you track down the one closest to you, why stop there?&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="font-family:Arial,sans-serif;"&gt;&lt;span style="color:#222222;"&gt;This cache is part of the Northeast Region Geotour. There are six exciting GeoTours making up this series which include a total of 50 accessible geocaches.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="https://coord.info/GT4F4"&gt;&lt;img src="https://img.geocaching.com:443/76de9cdc-8b3c-4816-8280-2fbc61852b60.jpg" /&gt;&lt;/a&gt; &lt;a href="https://coord.info/GT4F3"&gt;&lt;img src="https://img.geocaching.com:443/18d9b309-a90c-4900-a735-2eedd7912009.jpg" /&gt;&lt;/a&gt; &lt;a href="https://coord.info/GT4F2"&gt;&lt;img src="https://img.geocaching.com:443/0f404634-c476-4cd5-b8df-f85d6aa8069e.jpg" /&gt;&lt;/a&gt; &lt;a href="https://coord.info/GT4F1"&gt;&lt;img src="https://img.geocaching.com:443/dc93f2f7-97ae-4cb4-a9e1-8986f081414f.jpg" /&gt;&lt;/a&gt; &lt;a href="https://coord.info/GT4EF"&gt;&lt;img src="https://img.geocaching.com:443/179e8963-86e3-49a1-bc17-fd28c53b735a.jpg" /&gt;&lt;/a&gt; &lt;a href="https://coord.info/GT4F0"&gt;&lt;img src="https://img.geocaching.com:443/f6ab1d02-9794-4521-955f-0bcf19e3c566.jpg" /&gt;&lt;/a&gt;&lt;/p&gt;


</groundspeak:long_description><groundspeak:encoded_hints>La premiere marche du podium</groundspeak:encoded_hints><groundspeak:logs><groundspeak:log id="970776336"><groundspeak:date>2020-10-12T12:44:08</groundspeak:date><groundspeak:type>Archived</groundspeak:type><groundspeak:finder id="1199579">tontonlou</groundspeak:finder><groundspeak:text encoded="false">Voila, c'est fini.</groundspeak:text></groundspeak:log><groundspeak:log id="970547375"><groundspeak:date>2020-10-11T12:00:00</groundspeak:date><groundspeak:type>Found it</groundspeak:type><groundspeak:finder id="8479628">ronco38</groundspeak:finder><groundspeak:text encoded="false">trouvée 
